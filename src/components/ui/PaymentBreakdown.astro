---
import { Coins, Trophy, Settings } from 'lucide-react';
---

<div class="p-5 rounded-2xl bg-slate-900 border border-slate-800 shadow-inner relative overflow-hidden">
  <div class="absolute top-0 right-0 w-24 h-24 bg-emerald-500/5 rounded-full blur-2xl pointer-events-none"></div>
  
  <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-300 mb-3 flex items-center gap-1.5">
    <Coins className="w-4 h-4 text-emerald-400" />
    <span>Detalles del Pago</span>
  </h3>
  
  <div class="space-y-2.5 text-sm">
    <div class="flex justify-between items-center text-slate-400">
      <span>Costo de Entrada (por cupo)</span>
      <span class="font-semibold text-slate-200">20.00 USDT</span>
    </div>
    
    <div class="h-px bg-slate-800/80 my-2"></div>
    
    <div class="flex justify-between items-start text-xs">
      <div class="text-slate-400 space-y-0.5">
        <span class="font-medium text-emerald-400 flex items-center gap-1">
          <Trophy className="w-3.5 h-3.5 text-emerald-400" />
          <span>Pote de Premios</span>
        </span>
        <p class="text-[10px] text-slate-500">El 100% de este pote acumulado se entrega al primer lugar (único ganador) al finalizar el torneo.</p>
      </div>
      <span class="font-bold text-emerald-400 text-right shrink-0 ml-4">+15.00 USDT</span>
    </div>
    
    <div class="flex justify-between items-start text-xs pt-1">
      <div class="text-slate-400 space-y-0.5">
        <span class="font-medium text-teal-400 flex items-center gap-1">
          <Settings className="w-3.5 h-3.5 text-teal-400" />
          <span>Gastos Operativos</span>
        </span>
        <p class="text-[10px] text-slate-500">Mantenimiento técnico de la plataforma y soporte operativo.</p>
      </div>
      <span class="font-bold text-teal-400 text-right shrink-0 ml-4">+5.00 USDT</span>
    </div>
  </div>
</div>
