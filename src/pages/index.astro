---
import MainLayout from '../layouts/MainLayout.astro';
import { Trophy, Ticket, BookOpen } from 'lucide-react';

// Obtener sesión si existe
const user = Astro.locals.user;
const profile = Astro.locals.profile;
const isApproved = Astro.locals.isApproved;

// Definir fecha del primer partido en UTC
// 2026-06-11 22:30:00 UTC
const FIRST_MATCH_TIME = new Date('2026-06-11T22:30:00Z');
// El registro cierra 2 días antes (48 horas)
const REGISTRATION_DEADLINE = new Date(FIRST_MATCH_TIME.getTime() - 2 * 24 * 60 * 60 * 1000);
---

<MainLayout title="Quiniela Mundial 2026">
  <div class="relative bg-slate-950 text-slate-100 overflow-hidden py-12">
    
    <!-- Background premium gradients -->
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[30rem] h-[30rem] bg-indigo-500/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -top-40 right-10 w-96 h-96 bg-teal-500/10 rounded-full blur-3xl pointer-events-none"></div>

    <!-- Main Hero Content -->
    <main class="relative z-10 flex-grow flex items-center justify-center py-16 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl w-full text-center space-y-10">
        
        <!-- Badge -->
        <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs font-semibold select-none animate-pulse-subtle">
          <Trophy className="w-3.5 h-3.5 text-emerald-400" />
          <span>¡100% del pote acumulado para el primer lugar!</span>
        </div>

        <!-- Hero text -->
        <div class="space-y-4">
          <h1 class="text-4xl sm:text-6xl font-black tracking-tight text-white leading-tight">
            Demuestra tu instinto en la <br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 via-teal-300 to-indigo-400">
              Quiniela Mundial 2026
            </span>
          </h1>
          <p class="text-sm sm:text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed">
            Pronostica los resultados de los partidos, acumula puntos y compite contra otros participantes por el gran pote acumulado. ¿Tienes lo necesario para consagrarte campeón?
          </p>
        </div>

        <!-- Dynamic Counter & Prize Pool info -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl mx-auto pt-4">
          
          <!-- Countdown Card -->
          <div class="p-6 rounded-2xl bg-slate-900/60 border border-slate-800/80 backdrop-blur-md relative overflow-hidden flex flex-col justify-between min-h-[140px]">
            <div class="absolute top-0 right-0 w-20 h-20 bg-indigo-500/5 rounded-full blur-xl pointer-events-none"></div>
            <div class="text-xs uppercase font-bold text-slate-500 tracking-wider">El mundial comienza en</div>
            <div id="countdown" class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight font-mono py-2">
              --d --h --m --s
            </div>
            <div class="text-[10px] text-slate-500">
              Inicio: 11 de Junio, 2026 (22:30 UTC)
            </div>
          </div>

          <!-- Prize Pool Card -->
          <div class="p-6 rounded-2xl bg-slate-900/60 border border-slate-800/80 backdrop-blur-md relative overflow-hidden flex flex-col justify-between min-h-[140px]">
            <div class="absolute top-0 right-0 w-20 h-20 bg-emerald-500/5 rounded-full blur-xl pointer-events-none"></div>
            <div class="text-xs uppercase font-bold text-slate-500 tracking-wider">Pote Acumulado Actual</div>
            <div id="pote-display" class="text-3xl sm:text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-300 font-mono py-1">
              -- USDT
            </div>
            <div class="text-[10px] text-slate-400 font-medium">
              15 USDT directo al pozo por cada cupo aprobado
            </div>
          </div>

        </div>

        <!-- Action CTA buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
          <div id="registration-section" class="w-full sm:w-auto">
            <!-- Botón dinámico controlado por JS -->
            <a
              id="cta-register-btn"
              href="/register"
              class="w-full sm:w-auto px-8 py-4 bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-400 hover:to-teal-500 text-slate-950 rounded-2xl text-sm font-extrabold transition-all shadow-xl shadow-emerald-950/20 hover:shadow-emerald-950/40 hover:-translate-y-0.5 active:translate-y-0 flex items-center justify-center gap-2"
            >
              <Ticket className="w-4 h-4 text-slate-950" />
              <span>Registrarse y Participar</span>
            </a>
          </div>
          <a
            href="/faq"
            class="w-full sm:w-auto px-8 py-4 bg-slate-900 hover:bg-slate-850 text-slate-200 rounded-2xl text-sm font-bold border border-slate-800 transition-all flex items-center justify-center gap-2"
          >
            <BookOpen className="w-4 h-4 text-slate-400" />
            <span>Leer Reglas del Juego</span>
          </a>
        </div>

        <!-- Info legal simplificada -->
        <div class="text-xs text-slate-500 max-w-md mx-auto leading-relaxed pt-2">
          * Costo por cupo: 20 USDT (15 USDT destinados al pozo y 5 USDT para gastos operativos). 
          Solo para mayores de 18 años. El pozo acumulado final es íntegro para el 1er lugar.
        </div>

      </div>
    </main>

  </div>

  <!-- Cliente-side Scripts para cuenta regresiva, carga de Pote y cierre -->
  <script is:inline define:vars={{ FIRST_MATCH_TIME: FIRST_MATCH_TIME.toISOString(), REGISTRATION_DEADLINE: REGISTRATION_DEADLINE.toISOString() }}>
    // 1. Cuenta regresiva del mundial
    const matchTime = new Date(FIRST_MATCH_TIME).getTime();
    const countdownEl = document.getElementById('countdown');

    function updateCountdown() {
      const now = Date.now();
      const diff = matchTime - now;

      if (diff <= 0) {
        if (countdownEl) countdownEl.textContent = "¡EL MUNDIAL HA COMENZADO!";
        return;
      }

      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((diff % (1000 * 60)) / 1000);

      if (countdownEl) {
        countdownEl.textContent = `${days}d ${hours}h ${minutes}m ${seconds}s`;
      }
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);

    // 2. Control de Cierre de Inscripciones
    const deadlineTime = new Date(REGISTRATION_DEADLINE).getTime();
    const ctaBtn = document.getElementById('cta-register-btn');
    const isClosed = Date.now() >= deadlineTime;

    if (isClosed && ctaBtn) {
      ctaBtn.setAttribute('href', '#');
      ctaBtn.className = "w-full sm:w-auto px-8 py-4 bg-slate-800 text-slate-500 rounded-2xl text-sm font-extrabold cursor-not-allowed flex items-center justify-center gap-2 border border-slate-800";
      ctaBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-slate-500"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg><span>Registro Cerrado</span>`;
      
      const parent = document.getElementById('registration-section');
      if (parent) {
        const info = document.createElement('p');
        info.className = "text-[10px] text-rose-500 font-semibold mt-2 text-center";
        info.textContent = "Las inscripciones finalizaron el 9 de Junio.";
        parent.appendChild(info);
      }
    }

    // 3. Cargar dinámicamente el pote acumulado oficial
    const poteDisplay = document.getElementById('pote-display');
    async function loadPrizePool() {
      try {
        const response = await fetch('/api/prize-pool');
        if (response.ok) {
          const data = await response.json();
          if (poteDisplay && data && typeof data.totalPool === 'number') {
            poteDisplay.textContent = `${data.totalPool.toLocaleString('es-ES')} USDT`;
          }
        }
      } catch (err) {
        if (poteDisplay) poteDisplay.textContent = "0 USDT";
      }
    }
    loadPrizePool();
  </script>
</MainLayout>
