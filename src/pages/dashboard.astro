---
import MainLayout from '../layouts/MainLayout.astro';
import PredictionWarningBanner from '../components/islands/PredictionWarningBanner';
import PrizePoolDisplay from '../components/islands/PrizePoolDisplay';
import LiveScoreboard from '../components/islands/LiveScoreboard';
import StandingsTable from '../components/islands/StandingsTable';
import { Edit3, CreditCard, Shield, Info, MessageSquare, Sparkles } from 'lucide-react';

// Obtener datos del middleware
const user = Astro.locals.user;
const profile = Astro.locals.profile;
const entries = Astro.locals.entries || [];
const isApproved = Astro.locals.isApproved;


// Si no está logueado, redirigir a index
if (!user) {
  return Astro.redirect('/');
}

// Si no está aprobado (ningún cupo approved), redirigir a pending (a menos que sea admin)
if (!isApproved && profile?.role !== 'admin') {
  return Astro.redirect('/pending');
}

// Obtener los IDs de las entradas aprobadas del usuario para destacarlas en standings
const approvedEntryIds = entries.filter(e => e.status === 'approved').map(e => e.id);
---

<MainLayout title="Dashboard" userProfile={profile}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
    
    <!-- Alertas de Pronósticos Pendientes -->
    <PredictionWarningBanner client:load />

    <!-- Bienvenida y Accesos Rápidos -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 p-6 bg-slate-900/40 rounded-2xl border border-slate-800/80 backdrop-blur-sm relative overflow-hidden">
      <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-500/5 rounded-full blur-2xl pointer-events-none"></div>
      
      <div>
        <h1 class="text-2xl font-extrabold tracking-tight text-white sm:text-3xl">
          ¡Hola, {profile?.full_name}!
        </h1>
        <p class="text-xs text-slate-400 mt-1 leading-relaxed">
          Bienvenido a la Quiniela Mundial 2026. Tienes <span class="font-bold text-slate-200">{approvedEntryIds.length} {approvedEntryIds.length === 1 ? 'cupo activo' : 'cupos activos'}</span> participando en el torneo.
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <a
          href="/predictions/grupos"
          class="px-5 py-3 bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-400 hover:to-teal-500 text-slate-950 rounded-xl text-xs font-bold transition-all shadow-lg shadow-emerald-950/20 hover:-translate-y-0.5 flex items-center gap-1.5"
        >
          <Edit3 className="w-3.5 h-3.5 text-slate-950" /> Llenar Pronósticos
        </a>
        <a
          href="/my-entries"
          class="px-5 py-3 bg-slate-800 hover:bg-slate-700 text-slate-200 rounded-xl text-xs font-semibold border border-slate-700 transition-all hover:-translate-y-0.5 flex items-center gap-1.5"
        >
          <CreditCard className="w-3.5 h-3.5 text-slate-400" /> Comprar Más Cupos
        </a>
        {profile?.role === 'admin' && (
          <a
            href="/admin"
            class="px-5 py-3 bg-amber-500 hover:bg-amber-400 text-slate-950 rounded-xl text-xs font-bold transition-all shadow-lg shadow-amber-950/20 hover:-translate-y-0.5 flex items-center gap-1.5"
          >
            <Shield className="w-3.5 h-3.5 text-slate-950" /> Panel Admin
          </a>
        )}
      </div>
    </div>

    <!-- Pote Dinámico Actual -->
    <PrizePoolDisplay client:load />

    <!-- Marcadores en Vivo de la Jornada -->
    <LiveScoreboard client:load />

    <!-- Tabla de Clasificación de la Quiniela -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Tabla Principal (2 columnas de ancho en desktop) -->
      <div class="lg:col-span-2 space-y-6">
        <StandingsTable client:load myEntryIds={approvedEntryIds} />
      </div>

      <!-- Sidebar Informativo (1 columna de ancho) -->
      <div class="space-y-6">
        <!-- Tarjeta de Reglas de Puntuación -->
        <div class="p-5 rounded-2xl bg-slate-900/40 border border-slate-800/80 backdrop-blur-sm space-y-4">
          <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 flex items-center gap-1.5 border-b border-slate-900 pb-2.5">
            <Info className="w-4 h-4 text-emerald-400" /> Reglas de Puntuación
          </h3>
          
          <ul class="space-y-3 text-xs leading-relaxed text-slate-300">
            <li class="flex items-start gap-2">
              <span class="text-emerald-400 font-bold">3 pts</span>
              <div>
                <strong>Resultado Exacto</strong>
                <p class="text-[10px] text-slate-500">Acertaste la cantidad de goles de ambos equipos (ej. pronóstico 2-1, resultado 2-1).</p>
              </div>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-teal-400 font-bold">1 pt</span>
              <div>
                <strong>Resultado Parcial</strong>
                <p class="text-[10px] text-slate-500">Acertaste el ganador o empate, pero no los goles exactos (ej. pronóstico 3-1, resultado 2-0).</p>
              </div>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-slate-500 font-bold">0 pts</span>
              <div>
                <strong>Fallo</strong>
                <p class="text-[10px] text-slate-500">No acertaste el ganador ni el empate del partido.</p>
              </div>
            </li>
          </ul>
        </div>

        <!-- Tarjeta de Contacto / Soporte -->
        <div class="p-5 rounded-2xl bg-slate-900/40 border border-slate-800/80 backdrop-blur-sm space-y-3">
          <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 flex items-center gap-1.5">
            <MessageSquare className="w-4 h-4 text-emerald-400" /> Soporte y Organización
          </h3>
          <p class="text-xs text-slate-300 leading-relaxed">
            Si compraste un cupo adicional y tu comprobante sigue en revisión, o tienes dudas sobre las reglas del torneo, comunícate directamente con el administrador.
          </p>
          <div class="pt-1 text-[10px] text-slate-500 font-semibold uppercase tracking-wider flex items-center gap-1.5">
            <Sparkles className="w-3.5 h-3.5 text-amber-400 animate-pulse" />
            ¡Buena suerte en la quiniela!
          </div>
        </div>
      </div>
    </div>

  </div>
</MainLayout>
