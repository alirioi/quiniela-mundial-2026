---
import MainLayout from '../layouts/MainLayout.astro';
import PredictionWarningBanner from '../components/islands/PredictionWarningBanner';
import PrizePoolDisplay from '../components/islands/PrizePoolDisplay';
import LiveScoreboard from '../components/islands/LiveScoreboard';
import StandingsTable from '../components/islands/StandingsTable';
import { Edit3, CreditCard, Shield, Info, MessageSquare, Sparkles } from 'lucide-react';

// Obtener datos del middleware
const user = Astro.locals.user;
const profile = Astro.locals.profile;
const entries = Astro.locals.entries || [];
const isApproved = Astro.locals.isApproved;


// Si no está logueado, redirigir a index
if (!user) {
  return Astro.redirect('/');
}

// Si no está aprobado (ningún cupo approved), redirigir a pending (a menos que sea admin)
if (!isApproved && profile?.role !== 'admin') {
  return Astro.redirect('/pending');
}

// Obtener los IDs de las entradas aprobadas del usuario para destacarlas en standings
const approvedEntryIds = entries.filter(e => e.status === 'approved').map(e => e.id);
---

<MainLayout title="Dashboard" userProfile={profile}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
    
    <!-- Alertas de Pronósticos Pendientes -->
    <div>
      <PredictionWarningBanner client:load />
    </div>

    <!-- Bienvenida y Accesos Rápidos -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 p-6 bg-wc-card/90 rounded-2xl border border-wc-border backdrop-blur-sm relative overflow-hidden">
      <div class="absolute top-0 right-0 w-32 h-32 bg-wc-gold/5 rounded-full blur-2xl pointer-events-none"></div>
      
      <div>
        <h1 class="text-3xl font-bold uppercase tracking-wider text-white font-sports">
          ¡Hola, {profile?.full_name}!
        </h1>
        <p class="text-xs md:text-sm text-slate-400 mt-1 leading-relaxed">
          Bienvenido a la Quiniela Mundial 2026. Tienes <span class="font-bold text-wc-gold">{approvedEntryIds.length} {approvedEntryIds.length === 1 ? 'cupo activo' : 'cupos activos'}</span> participando en el torneo.
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <a
          href="/predictions/grupos"
          class="px-5 py-3 bg-gradient-to-r from-wc-gold to-amber-500 hover:from-amber-400 hover:to-wc-gold text-slate-950 rounded-xl text-sm font-bold tracking-wide transition-all shadow-lg shadow-wc-gold/20 hover:-translate-y-0.5 flex items-center gap-2 font-sports cursor-pointer"
        >
          <Edit3 className="w-5 h-5 text-slate-950" strokeWidth={2.5} /> Llenar Pronósticos
        </a>
        <a
          href="/my-entries"
          class="px-5 py-3 bg-wc-dark hover:bg-wc-border/50 text-white rounded-xl text-sm font-bold tracking-wide border border-wc-border transition-all hover:-translate-y-0.5 flex items-center gap-2 font-sports cursor-pointer"
        >
          <CreditCard className="w-5 h-5 text-slate-300" strokeWidth={2.5} /> Comprar Más Cupos
        </a>
        {profile?.role === 'admin' && (
          <a
            href="/admin"
            class="px-5 py-3 bg-wc-red hover:bg-red-500 text-white rounded-xl text-sm font-bold tracking-wide transition-all shadow-lg shadow-wc-red/20 hover:-translate-y-0.5 flex items-center gap-2 font-sports cursor-pointer"
          >
            <Shield className="w-5 h-5 text-white" strokeWidth={2.5} /> Panel Admin
          </a>
        )}
      </div>
    </div>

    <!-- Pote Dinámico Actual -->
    <div>
      <PrizePoolDisplay client:load />
    </div>

    <!-- Marcadores en Vivo de la Jornada -->
    <div class="space-y-2">
      <LiveScoreboard client:load />
      <div class="text-xs md:text-sm text-slate-400 flex items-center justify-center gap-1.5 px-4 py-1 bg-wc-dark/30 rounded-lg max-w-fit mx-auto border border-wc-border/20">
        <Info className="w-4 h-4 text-wc-gold shrink-0" strokeWidth={2.5} />
        <span>Los resultados y puntuaciones de la quiniela pueden tardar unos minutos en actualizarse tras finalizar el encuentro.</span>
      </div>
    </div>

    <!-- Tabla de Clasificación de la Quiniela -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Tabla Principal (2 columnas de ancho en desktop) -->
      <div class="lg:col-span-2 space-y-6">
        <StandingsTable client:load myEntryIds={approvedEntryIds} />
      </div>

      <!-- Sidebar Informativo (1 columna de ancho) -->
      <div class="space-y-6">
        <!-- Tarjeta de Reglas de Puntuación -->
        <div class="p-5 rounded-2xl bg-wc-card border border-wc-border backdrop-blur-sm space-y-4">
          <h3 class="text-sm font-bold uppercase tracking-wider text-white flex items-center gap-2 border-b border-wc-border pb-2.5 font-sports">
            <Info className="w-5 h-5 text-wc-gold" strokeWidth={2.5} /> Reglas de Puntuación
          </h3>
          
          <ul class="space-y-3 text-xs md:text-sm leading-relaxed text-slate-300">
            <li class="flex items-start gap-2.5">
              <span class="text-wc-gold font-bold font-sports text-sm md:text-base mt-0.5 w-12 shrink-0 text-left">3 pts</span>
              <div>
                <strong class="text-slate-200 text-xs md:text-sm">Resultado Exacto</strong>
                <p class="text-xs md:text-sm text-slate-400 mt-0.5">Acertaste la cantidad de goles de ambos equipos (ej. pronóstico 2-1, resultado 2-1).</p>
              </div>
            </li>
            <li class="flex items-start gap-2.5">
              <span class="text-wc-blue font-bold font-sports text-sm md:text-base mt-0.5 w-12 shrink-0 text-left">1 pt</span>
              <div>
                <strong class="text-slate-200 text-xs md:text-sm">Resultado Parcial</strong>
                <p class="text-xs md:text-sm text-slate-400 mt-0.5">Acertaste el ganador o empate, pero no los goles exactos (ej. pronóstico 3-1, resultado 2-0).</p>
              </div>
            </li>
            <li class="flex items-start gap-2.5">
              <span class="text-slate-500 font-bold font-sports text-sm md:text-base mt-0.5 w-12 shrink-0 text-left">0 pts</span>
              <div>
                <strong class="text-slate-300 text-xs md:text-sm">Fallo</strong>
                <p class="text-xs md:text-sm text-slate-400 mt-0.5">No acertaste el ganador ni el empate del partido.</p>
              </div>
            </li>
          </ul>
        </div>

        <!-- Tarjeta de Contacto / Soporte -->
        <div class="p-5 rounded-2xl bg-wc-card border border-wc-border backdrop-blur-sm space-y-3">
          <h3 class="text-sm font-bold uppercase tracking-wider text-white flex items-center gap-2 font-sports">
            <MessageSquare className="w-5 h-5 text-wc-gold" strokeWidth={2.5} /> Soporte y Organización
          </h3>
          <p class="text-xs md:text-sm text-slate-300 leading-relaxed">
            Si compraste un cupo adicional y tu comprobante sigue en revisión, o tienes dudas sobre las reglas del torneo, comunícate directamente con el administrador.
          </p>
          <div class="pt-1 text-xs md:text-sm text-slate-400 font-bold uppercase tracking-wider flex items-center gap-2 font-sports">
            <Sparkles className="w-4.5 h-4.5 text-wc-gold animate-pulse" strokeWidth={2.5} />
            ¡Buena suerte en la quiniela!
          </div>
        </div>
      </div>
    </div>

  </div>
</MainLayout>
