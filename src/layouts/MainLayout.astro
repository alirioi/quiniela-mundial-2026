---
import '../styles/global.css';
import { Trophy, Shield } from 'lucide-react';

interface Props {
  title: string;
  description?: string;
  userProfile?: {
    full_name: string;
    role: string;
    email: string;
  } | null;
}

const { title, description = 'Quiniela del Mundial 2026', userProfile } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} | Quiniela Mundial 2026</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <style>
      body {
        font-family: 'Outfit', sans-serif;
      }
      .font-sports {
        font-family: 'Bebas Neue', sans-serif;
        letter-spacing: 0.05em;
      }
    </style>
  </head>
  <body class="bg-wc-dark text-slate-100 min-h-screen flex flex-col selection:bg-wc-gold selection:text-slate-950 bg-radial-gradient">
    <!-- Premium Header -->
    <header class="border-b border-wc-border/80 bg-wc-card/40 backdrop-blur-md sticky top-0 z-40">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href={userProfile ? "/dashboard" : "/"} class="flex items-center space-x-2 group">
          <Trophy className="w-5.5 h-5.5 text-wc-gold transition-transform group-hover:scale-110 duration-200" strokeWidth={2.5} />
          <span class="font-sports font-black tracking-wider text-transparent bg-clip-text bg-gradient-to-r from-wc-red via-wc-gold to-wc-green text-2xl group-hover:opacity-90 transition-opacity">
            Quiniela 2026
          </span>
        </a>

        <nav class="hidden md:flex items-center space-x-6 text-sm font-medium">
          {userProfile && (
            <>
              <a href="/dashboard" class="text-slate-300 hover:text-wc-gold transition-colors">Dashboard</a>
              <a href="/my-entries" class="text-slate-300 hover:text-wc-gold transition-colors">Mis Cupos</a>
            </>
          )}
          <a href="/faq" class="text-slate-300 hover:text-wc-gold transition-colors">Reglas y FAQ</a>
          {userProfile?.role === 'admin' && (
            <a href="/admin" class="text-wc-gold hover:text-yellow-400 font-semibold transition-colors flex items-center gap-1.5">
              <Shield className="w-4.5 h-4.5 text-wc-gold animate-pulse-subtle" strokeWidth={2.5} />
              Admin
            </a>
          )}
        </nav>

        <div class="flex items-center space-x-4">
          {userProfile ? (
            <div class="flex items-center space-x-4">
              <span class="hidden sm:inline text-xs text-slate-400 font-medium">
                Hola, <span class="text-slate-200">{userProfile.full_name}</span>
              </span>
              <button
                id="logout-btn"
                class="px-3.5 py-1.5 rounded-lg text-xs font-semibold bg-slate-800 hover:bg-red-950/40 hover:text-red-400 border border-slate-700 hover:border-red-900/50 transition-all duration-200"
              >
                Cerrar Sesión
              </button>
            </div>
          ) : (
            <a
              href="/login"
              class="px-4 py-2 rounded-lg text-sm font-semibold bg-gradient-to-r from-wc-gold to-amber-500 hover:from-yellow-400 hover:to-amber-400 text-slate-950 shadow-lg shadow-wc-gold/10 hover:shadow-wc-gold/25 transition-all duration-200"
            >
              Iniciar Sesión
            </a>
          )}
        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-wc-border bg-wc-dark/85 py-8 text-center text-xs text-slate-500">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center justify-center gap-1.5">
        <p class="flex items-center gap-1.5">
          <Trophy className="w-4.5 h-4.5 text-wc-gold/80" strokeWidth={2.5} />
          <span>Quiniela Mundial 2026 — Para uso de amigos y organizadores.</span>
        </p>
        <p class="text-xs text-slate-500">Desarrollado con Astro, React y Supabase.</p>
      </div>
    </footer>

    {userProfile && (
      <script>
        document.getElementById('logout-btn')?.addEventListener('click', async () => {
          try {
            const response = await fetch('/api/auth/logout', { method: 'POST' });
            if (response.ok) {
              window.location.href = '/';
            } else {
              console.error('Error al cerrar sesión');
            }
          } catch (e) {
            console.error('Error de red', e);
          }
        });
      </script>
    )}
  </body>
</html>
