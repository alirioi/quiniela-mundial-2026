---
export const prerender = false;
import MainLayout from '../layouts/MainLayout.astro';
import MundialDashboard from '../components/islands/MundialDashboard';
import { supabaseAdmin } from '../lib/supabase-server';

const profile = Astro.locals.profile;

// Fetch all matches from the database
const { data: matches, error } = await supabaseAdmin
  .from('matches')
  .select(`
    id,
    phase_id,
    home_team,
    away_team,
    match_time,
    home_score,
    away_score,
    status,
    group_name,
    match_number,
    penalty_winner
  `)
  .order('match_time', { ascending: true });

if (error) {
  console.error('Error fetching matches for Mundial page:', error);
}

const matchData = matches || [];
---

<MainLayout 
  title="El Mundial" 
  description="Sigue el calendario completo, grupos y resultados en tiempo real del Mundial 2026. La información más actualizada para tus pronósticos de la quiniela."
  userProfile={profile}
>
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <MundialDashboard client:load matches={matchData} />
  </div>
</MainLayout>
