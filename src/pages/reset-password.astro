---
export const prerender = false;
import MainLayout from '../layouts/MainLayout.astro';
import { Loader2, AlertTriangle, Lock, Check } from 'lucide-react';
---

<MainLayout title="Nueva Contraseña">
  <div class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-4 py-12 sm:px-6 lg:px-8 bg-radial-gradient">
    <div class="max-w-md w-full space-y-8 bg-wc-card/65 backdrop-blur-md p-8 rounded-2xl border border-wc-border shadow-2xl relative overflow-hidden">
      <!-- Decorative gradients -->
      <div class="absolute -top-10 -right-10 w-40 h-40 bg-wc-gold/10 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-wc-blue/10 rounded-full blur-3xl pointer-events-none"></div>

      <!-- Pantalla de Carga y Validación Inicial -->
      <div id="loading-screen" class="text-center py-8 space-y-4 flex flex-col items-center">
        <Loader2 className="w-10 h-10 animate-spin text-wc-gold" strokeWidth={2.5} />
        <p class="text-sm text-slate-400">Verificando enlace de recuperación...</p>
      </div>

      <!-- Pantalla de Error -->
      <div id="error-screen" class="hidden text-center py-8 space-y-4 flex flex-col items-center">
        <AlertTriangle className="w-14 h-14 text-rose-500" strokeWidth={2.5} />
        <h2 class="text-xl font-sports font-bold text-white tracking-wider">Error de Validación</h2>
        <p id="validation-error-text" class="text-sm text-slate-450">El enlace de recuperación no es válido o ha expirado.</p>
        <div class="pt-4">
          <a href="/forgot-password" class="px-5 py-2.5 bg-wc-dark hover:bg-wc-card text-slate-200 border border-wc-border rounded-xl text-xs font-bold uppercase transition-colors">
            Solicitar nuevo enlace
          </a>
        </div>
      </div>

      <!-- Formulario de Nueva Contraseña -->
      <div id="reset-form-container" class="hidden space-y-6">
        <div class="text-center relative flex flex-col items-center">
          <Lock className="w-14 h-14 text-wc-gold mb-3" strokeWidth={2.5} />
          <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
            Nueva Contraseña
          </h1>
          <p class="mt-3 text-sm text-slate-350 font-medium">
            Ingresa tu nueva contraseña para tu cuenta.
          </p>
        </div>

        <form id="reset-form" class="space-y-6 relative">
          <div id="error-message" class="hidden p-3.5 rounded-lg bg-red-950/40 border border-red-900/50 text-red-400 text-xs font-semibold">
          </div>
          
          <div id="success-message" class="hidden p-3.5 rounded-lg bg-emerald-950/45 border border-wc-green/30 text-wc-green text-xs font-semibold">
          </div>

          <div class="space-y-4">
            <div>
              <label for="password" class="block text-xs font-bold uppercase tracking-wider text-slate-300 mb-1.5">
                Nueva Contraseña
              </label>
              <input
                id="password"
                name="password"
                type="password"
                required
                minlength="6"
                class="w-full px-4 py-3 rounded-xl bg-wc-dark border border-wc-border text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-wc-gold/50 focus:border-wc-gold transition-all duration-200 text-sm font-medium"
                placeholder="Mínimo 6 caracteres"
              />
            </div>

            <div>
              <label for="confirm-password" class="block text-xs font-bold uppercase tracking-wider text-slate-300 mb-1.5">
                Confirmar Contraseña
              </label>
              <input
                id="confirm-password"
                name="confirm-password"
                type="password"
                required
                minlength="6"
                class="w-full px-4 py-3 rounded-xl bg-wc-dark border border-wc-border text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-wc-gold/50 focus:border-wc-gold transition-all duration-200 text-sm font-medium"
                placeholder="Confirma tu contraseña"
              />
            </div>
          </div>

          <div>
            <button
              type="submit"
              id="submit-btn"
              class="w-full py-4 px-4 rounded-xl bg-gradient-to-r from-wc-gold to-amber-500 hover:from-yellow-400 hover:to-amber-400 text-slate-950 shadow-lg shadow-wc-gold/15 hover:shadow-wc-gold/30 hover:-translate-y-0.5 transition-all duration-200 flex items-center justify-center gap-2 group font-sports font-black text-lg tracking-wider"
            >
              <span>Actualizar Contraseña</span>
              <Check className="w-5 h-5 text-slate-950 group-hover:scale-110 transition-transform" strokeWidth={2.5} />
            </button>
          </div>
        </form>
      </div>

    </div>
  </div>

  <script>
    import { supabase } from '../lib/supabase-browser';

    const loadingScreen = document.getElementById('loading-screen');
    const errorScreen = document.getElementById('error-screen');
    const validationErrorText = document.getElementById('validation-error-text');
    const resetFormContainer = document.getElementById('reset-form-container');

    const form = document.getElementById('reset-form') as HTMLFormElement;
    const errorDiv = document.getElementById('error-message');
    const successDiv = document.getElementById('success-message');
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const CHECK_SVG = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-slate-950 group-hover:scale-110 transition-transform"><polyline points="20 6 9 17 4 12"></polyline></svg>`;

    function showError(message: string) {
      if (loadingScreen && errorScreen && validationErrorText) {
        loadingScreen.classList.add('hidden');
        validationErrorText.textContent = message;
        errorScreen.classList.remove('hidden');
      }
    }

    async function init() {
      // Intentar extraer tokens del hash de la URL
      const hash = window.location.hash;
      if (hash) {
        const params = new URLSearchParams(hash.substring(1));
        const accessToken = params.get('access_token');
        const refreshToken = params.get('refresh_token');

        if (accessToken && refreshToken) {
          try {
            // Sincronizar sesión con cookies del servidor
            const sessionRes = await fetch('/api/auth/session', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ accessToken, refreshToken })
            });

            if (sessionRes.ok) {
              // Cargar la sesión en el cliente de Supabase
              const { error } = await supabase.auth.setSession({
                access_token: accessToken,
                refresh_token: refreshToken
              });

              if (!error) {
                loadingScreen?.classList.add('hidden');
                resetFormContainer?.classList.remove('hidden');
              } else {
                showError('Error al establecer la sesión cliente: ' + error.message);
              }
            } else {
              showError('Error al sincronizar la sesión con el servidor.');
            }
          } catch (err) {
            showError('Error de red al establecer sesión.');
          }
        } else {
          showError('El enlace de recuperación no es válido o ha expirado.');
        }
      } else {
        // Si no hay hash, comprobamos si ya hay una sesión activa
        const { data: { session } } = await supabase.auth.getSession();
        if (session) {
          loadingScreen?.classList.add('hidden');
          resetFormContainer?.classList.remove('hidden');
        } else {
          showError('Acceso no autorizado. Utiliza el enlace que recibiste en tu correo para restablecer tu contraseña.');
        }
      }
    }

    // Iniciar verificación
    init();

    // Evento de submit del formulario
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!errorDiv || !successDiv || !submitBtn) return;

      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');

      const password = (document.getElementById('password') as HTMLInputElement).value;
      const confirmPassword = (document.getElementById('confirm-password') as HTMLInputElement).value;

      if (password !== confirmPassword) {
        errorDiv.textContent = 'Las contraseñas no coinciden.';
        errorDiv.classList.remove('hidden');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span>Actualizando...</span>';

      try {
        // Actualizar contraseña en Supabase Auth
        const { error } = await supabase.auth.updateUser({ password });

        if (error) {
          errorDiv.textContent = error.message;
          errorDiv.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.innerHTML = `<span>Actualizar Contraseña</span>${CHECK_SVG}`;
        } else {
          successDiv.textContent = 'Tu contraseña ha sido actualizada con éxito. Redirigiendo...';
          successDiv.classList.remove('hidden');
          
          setTimeout(() => {
            window.location.href = '/';
          }, 3000);
        }
      } catch (err) {
        errorDiv.textContent = 'Error al actualizar la contraseña.';
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.innerHTML = `<span>Actualizar Contraseña</span>${CHECK_SVG}`;
      }
    });
  </script>
</MainLayout>
