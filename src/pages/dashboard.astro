---
export const prerender = false;
import MainLayout from '../layouts/MainLayout.astro';
import PredictionWarningBanner from '../components/islands/PredictionWarningBanner';
import PrizePoolDisplay from '../components/islands/PrizePoolDisplay';
import LiveScoreboard from '../components/islands/LiveScoreboard';
import LiveMatchWidget from '../components/islands/LiveMatchWidget';
import StandingsTable from '../components/islands/StandingsTable';
import LiveGroupStandingsWidget from '../components/islands/LiveGroupStandingsWidget';
import { supabaseAdmin } from '../lib/supabase-server';
import { Edit3, CreditCard, Shield, Info, MessageSquare, Sparkles, BarChart3 } from 'lucide-react';

// Obtener datos del middleware
const user = Astro.locals.user;
const profile = Astro.locals.profile;
const entries = Astro.locals.entries || [];
const isApproved = Astro.locals.isApproved;


// Si no está logueado, redirigir a index
if (!user) {
  return Astro.redirect('/');
}

// Si no está aprobado (ningún cupo approved), redirigir a pending (a menos que sea admin)
if (!isApproved && profile?.role !== 'admin') {
  return Astro.redirect('/pending');
}

// Obtener los IDs de las entradas aprobadas del usuario para destacarlas en standings
const approvedEntryIds = entries.filter(e => e.status === 'approved').map(e => e.id);
const approvedEntries = entries
  .filter(e => e.status === 'approved')
  .map(e => ({ id: e.id, display_name: e.display_name }));

// Obtener todos los partidos para calcular la tabla del grupo activo
const [matchesRes, playersRes, goldEntriesRes] = await Promise.all([
  supabaseAdmin
    .from('matches')
    .select(`
      id,
      phase_id,
      home_team,
      away_team,
      match_time,
      home_score,
      away_score,
      status,
      group_name,
      match_number
    `)
    .order('match_time', { ascending: true }),
  supabaseAdmin
    .from('player_stats')
    .select('id, name, team, goals, assists')
    .order('goals', { ascending: false })
    .order('assists', { ascending: false })
    .order('name', { ascending: true })
    .limit(5),
  supabaseAdmin
    .from('entries')
    .select('predicted_champion, profiles!inner(role)')
    .eq('status', 'approved')
    .neq('profiles.role', 'admin')
]);

if (matchesRes.error) {
  console.error('Error al obtener partidos para el widget del dashboard:', matchesRes.error);
}
if (playersRes.error) {
  console.error('Error al obtener goleadores para el widget del dashboard:', playersRes.error);
}

const matchData = matchesRes.data || [];
const playerData = playersRes.data || [];

// Procesar el top 6 de equipos del Pronóstico de Oro
const counts: Record<string, number> = {};
goldEntriesRes.data?.forEach((e: any) => {
  if (e.predicted_champion) {
    const team = e.predicted_champion.trim();
    counts[team] = (counts[team] || 0) + 1;
  }
});

const top6GoldTeams = Object.entries(counts)
  .map(([team, count]) => ({ team, count }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 6)
  .map(item => item.team);

const fallbackTeams = ["Argentina", "Brasil", "Francia", "Alemania", "España", "Inglaterra"];
const goldTeamsSet = new Set(top6GoldTeams);
for (const fallback of fallbackTeams) {
  if (goldTeamsSet.size >= 6) break;
  goldTeamsSet.add(fallback);
}
const finalGoldTeams = Array.from(goldTeamsSet);
---

<MainLayout title="Dashboard" userProfile={profile}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
    
    <!-- Alertas de Pronósticos Pendientes -->
    <div>
      <PredictionWarningBanner client:load />
    </div>

    <!-- Aviso de Fase Eliminatoria (Empieza mañana) -->
    <div class="bg-gradient-to-r from-wc-gold/25 via-amber-500/10 to-transparent border border-wc-gold/40 rounded-2xl p-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4 shadow-lg">
      <div class="flex items-start sm:items-center gap-3.5 w-full">
        <div class="p-3 bg-wc-gold/15 rounded-xl border border-wc-gold/30 text-wc-gold shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <div>
          <h4 class="font-sports font-black text-sm uppercase tracking-wider text-wc-gold">
            ¡Fase Eliminatoria Activa!
          </h4>
          <p class="text-xs sm:text-sm text-slate-200 mt-1.5 leading-relaxed">
            Los clasificados están definidos. Ingresa a la sección de pronósticos para configurar tus marcadores en los partidos de eliminación directa.
          </p>
        </div>
      </div>
    </div>


    <!-- Bienvenida y Accesos Rápidos -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 p-6 bg-wc-card/90 rounded-2xl border border-wc-border backdrop-blur-sm relative overflow-hidden">
      <div class="absolute top-0 right-0 w-32 h-32 bg-wc-gold/5 rounded-full blur-2xl pointer-events-none"></div>
      
      <div>
        <h1 class="text-3xl font-bold uppercase tracking-wider text-white font-sports">
          ¡Hola, {profile?.full_name?.split(' ')[0]}!
        </h1>
        <p class="text-xs md:text-sm text-slate-400 mt-1 leading-relaxed">
          Bienvenido a la Quiniela Mundial 2026. Tienes <span class="font-bold text-wc-gold">{approvedEntryIds.length} {approvedEntryIds.length === 1 ? 'cupo activo' : 'cupos activos'}</span> participando en el torneo.
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <a
          href="/predictions"
          class="px-5 py-3 bg-gradient-to-r from-wc-gold to-amber-500 hover:from-amber-400 hover:to-wc-gold text-slate-950 rounded-xl text-sm font-bold tracking-wide transition-all shadow-lg shadow-wc-gold/20 hover:-translate-y-0.5 flex items-center gap-2 font-sports cursor-pointer"
        >
          <Edit3 className="w-5 h-5 text-slate-950" strokeWidth={2.5} /> Llenar Pronósticos
        </a>
        {profile?.role === 'admin' && (
          <a
            href="/admin"
            class="px-5 py-3 bg-wc-red hover:bg-red-500 text-white rounded-xl text-sm font-bold tracking-wide transition-all shadow-lg shadow-wc-red/20 hover:-translate-y-0.5 flex items-center gap-2 font-sports cursor-pointer"
          >
            <Shield className="w-5 h-5 text-white" strokeWidth={2.5} /> Panel Admin
          </a>
        )}
      </div>
    </div>

    <!-- Pote Dinámico Actual eliminado de aquí para moverlo abajo -->

    <!-- Marcadores en Vivo de la Jornada -->
    <div class="space-y-2">
      <LiveScoreboard client:load />
      <div class="text-xs md:text-sm text-slate-400 flex items-center justify-center gap-1.5 px-4 py-1 bg-wc-dark/30 rounded-lg max-w-fit mx-auto border border-wc-border/20">
        <Info className="w-4 h-4 text-wc-gold shrink-0" strokeWidth={2.5} />
        <span>Los resultados y puntuaciones de la quiniela pueden tardar unos minutos en actualizarse tras finalizar el encuentro.</span>
      </div>
    </div>

    <!-- Tabla de Clasificación de la Quiniela y Sidebar Widgets -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8 items-start">
      
      <!-- Pote Dinámico Actual (Desktop: col 3, row 1. Mobile: 1st) -->
      <div class="lg:col-span-1 lg:col-start-3 lg:row-start-1">
        <PrizePoolDisplay client:load />
      </div>

      <!-- Partido en Vivo (Desktop: col 3, row 2. Mobile: 2nd) -->
      <div class="lg:col-span-1 lg:col-start-3 lg:row-start-2">
        <LiveMatchWidget client:load approvedEntries={approvedEntries} />
      </div>

      <!-- Tabla Principal (Desktop: cols 1-2, rows 1 to 4. Mobile: 3rd) -->
      <div class="lg:col-span-2 lg:col-start-1 lg:row-start-1 lg:row-span-4 flex flex-col gap-6">
        <StandingsTable client:visible myEntryIds={approvedEntryIds} isAdmin={profile?.role === 'admin'} />
      </div>

      <!-- Tarjeta de Estadísticas del Mundial (Desktop: col 3, row 3. Mobile: 4th) -->
      <div class="lg:col-span-1 lg:col-start-3 lg:row-start-3">
        <LiveGroupStandingsWidget 
          client:load 
          initialMatches={matchData} 
          initialPlayers={playerData}
          goldTeams={finalGoldTeams}
        />
      </div>
    </div>

  </div>
</MainLayout>
