---
import '../styles/global.css';
import { Trophy, Shield } from 'lucide-react';
import Logo from '../components/Logo.astro';

interface Props {
  title: string;
  description?: string;
  userProfile?: {
    full_name: string;
    role: string;
    email: string;
  } | null;
}

const { title, description = 'Quiniela del Mundial 2026', userProfile } = Astro.props;
const currentPath = Astro.url.pathname;
const isActive = (path: string) => {
  if (path === '/') return currentPath === '/';
  return currentPath === path || currentPath.startsWith(path + '/');
};
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Theme Initialization (prevents FOUC) -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'dark'; // Default to dark as it is the foundational theme
      })();

      if (theme === 'light') {
        document.documentElement.classList.add('light');
      } else {
        document.documentElement.classList.remove('light');
      }
    </script>

    <meta name="description" content={description} />
    <title>{title} | Quiniela Mundial 2026</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <style>
      body {
        font-family: 'Outfit', sans-serif;
      }
      .font-sports {
        font-family: 'Bebas Neue', sans-serif;
        letter-spacing: 0.05em;
      }
    </style>

    <!-- Google Analytics Check -->
    <script is:inline>
      (function() {
        const consent = localStorage.getItem('cookie-consent');
        if (consent === 'accepted') {
          const script = document.createElement('script');
          script.async = true;
          script.src = 'https://www.googletagmanager.com/gtag/js?id=G-J1JCNSPG92';
          document.head.appendChild(script);

          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-J1JCNSPG92');
          window.gtag = gtag;
        }
      })();
    </script>
  </head>
  <body class="bg-wc-dark text-slate-100 min-h-screen flex flex-col selection:bg-wc-gold selection:text-slate-950 bg-radial-gradient">
    <!-- Premium Header -->
    <header id="main-header" class="border-b border-wc-border/80 bg-wc-card/40 backdrop-blur-md sticky top-0 z-40 transition-transform duration-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
        <a href={userProfile ? "/dashboard" : "/"} class="flex items-center group hover:opacity-90 transition-opacity" aria-label="Volver al inicio">
          <Logo mode="horizontal" size="small" />
        </a>

        <nav class="hidden md:flex items-center space-x-6 text-sm font-medium">
          {userProfile && (
            <>
              <a href="/dashboard" class={`transition-colors ${isActive('/dashboard') ? 'text-wc-gold font-bold' : 'text-slate-300 hover:text-wc-gold'}`}>Dashboard</a>
              <a href="/predictions" class={`transition-colors ${isActive('/predictions') ? 'text-wc-gold font-bold' : 'text-slate-300 hover:text-wc-gold'}`}>Pronósticos</a>
              <a href="/my-entries" class={`transition-colors ${isActive('/my-entries') ? 'text-wc-gold font-bold' : 'text-slate-300 hover:text-wc-gold'}`}>Mis Cupos</a>
              <a href="/profile" class={`transition-colors ${isActive('/profile') ? 'text-wc-gold font-bold' : 'text-slate-300 hover:text-wc-gold'}`}>Mi Perfil</a>
            </>
          )}
          <a href="/faq" class={`transition-colors ${isActive('/faq') ? 'text-wc-gold font-bold' : 'text-slate-300 hover:text-wc-gold'}`}>Reglas y FAQ</a>
          <a href="/mundial" class={`transition-colors ${isActive('/mundial') ? 'text-wc-gold font-bold' : 'text-slate-300 hover:text-wc-gold'}`}>El Mundial</a>
          {userProfile?.role === 'admin' && (
            <a href="/admin" class={`font-semibold transition-colors flex items-center gap-1.5 ${isActive('/admin') ? 'text-yellow-400 font-bold' : 'text-wc-gold hover:text-yellow-400'}`}>
              <Shield className="w-4.5 h-4.5 text-wc-gold animate-pulse-subtle" strokeWidth={2.5} />
              Admin
            </a>
          )}
        </nav>

        <div class="flex items-center space-x-2 sm:space-x-4">
          {userProfile ? (
            <div class="flex items-center space-x-2 sm:space-x-4">
              <span class="hidden lg:inline text-sm text-slate-350 font-semibold">
                Hola, <span class="text-slate-100">{userProfile.full_name.split(' ')[0]}</span>
              </span>
              <button
                id="logout-btn"
                class="hidden sm:inline-block px-4 py-2 rounded-xl text-xs sm:text-sm font-bold bg-slate-800 hover:bg-red-950/40 hover:text-red-400 border border-slate-700 hover:border-red-900/50 transition-all duration-200"
              >
                Cerrar Sesión
              </button>
            </div>
          ) : (
            <div class="hidden sm:flex items-center gap-2">
              <a
                href="/login"
                class="px-4 py-2 rounded-lg text-sm font-semibold text-slate-300 hover:text-white hover:bg-slate-800 transition-colors"
              >
                Ingresar
              </a>
              <a
                href="/register"
                class="px-4 py-2 rounded-lg text-sm font-semibold bg-gradient-to-r from-wc-gold to-amber-500 hover:from-yellow-400 hover:to-amber-400 text-slate-950 shadow-lg shadow-wc-gold/10 hover:shadow-wc-gold/25 transition-all duration-200"
              >
                Registrar
              </a>
            </div>
          )}

          <!-- Theme Toggle Button -->
          <button
            id="theme-toggle"
            class="p-2 rounded-xl text-slate-400 hover:text-white bg-slate-800/40 hover:bg-slate-800 border border-slate-700/60 transition-all focus:outline-none flex items-center justify-center"
            aria-label="Cambiar tema"
          >
            <!-- Sun Icon (visible in dark mode) -->
            <svg id="theme-toggle-light-icon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <!-- Moon Icon (visible in light mode) -->
            <svg id="theme-toggle-dark-icon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>

          <!-- Hamburger Button -->
          <button
            id="mobile-menu-toggle"
            class="md:hidden p-2 rounded-xl text-slate-400 hover:text-white bg-slate-800/40 hover:bg-slate-800 border border-slate-700/60 transition-all focus:outline-none"
            aria-label="Menú de navegación"
          >
            <svg id="hamburger-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Mobile Menu (hidden by default) -->
    <div
      id="mobile-menu"
      class="hidden md:hidden fixed top-20 left-0 right-0 border-b border-wc-border/90 bg-wc-card/95 backdrop-blur-lg transition-all duration-300 z-50 max-h-[calc(100vh-5rem)] overflow-y-auto"
    >
      <div class="px-4 py-4 space-y-3 font-medium text-sm">
        {userProfile && (
          <div class="pb-3 border-b border-wc-border/50">
            <span class="text-xs text-slate-400 block mb-1">Sesión iniciada como:</span>
            <span class="text-slate-200 font-bold block">{userProfile.full_name}</span>
            <span class="text-xs text-slate-500 block">{userProfile.email}</span>
          </div>
        )}

        {userProfile && (
          <>
            <a href="/dashboard" class={`block py-2 transition-colors ${isActive('/dashboard') ? 'text-wc-gold font-bold border-l-2 border-wc-gold pl-2' : 'text-slate-350 hover:text-wc-gold'}`}>Dashboard</a>
            <a href="/predictions" class={`block py-2 transition-colors ${isActive('/predictions') ? 'text-wc-gold font-bold border-l-2 border-wc-gold pl-2' : 'text-slate-350 hover:text-wc-gold'}`}>Pronósticos</a>
            <a href="/my-entries" class={`block py-2 transition-colors ${isActive('/my-entries') ? 'text-wc-gold font-bold border-l-2 border-wc-gold pl-2' : 'text-slate-350 hover:text-wc-gold'}`}>Mis Cupos</a>
            <a href="/profile" class={`block py-2 transition-colors ${isActive('/profile') ? 'text-wc-gold font-bold border-l-2 border-wc-gold pl-2' : 'text-slate-350 hover:text-wc-gold'}`}>Mi Perfil</a>
          </>
        )}
        <a href="/faq" class={`block py-2 transition-colors ${isActive('/faq') ? 'text-wc-gold font-bold border-l-2 border-wc-gold pl-2' : 'text-slate-350 hover:text-wc-gold'}`}>Reglas y FAQ</a>
        <a href="/mundial" class={`block py-2 transition-colors ${isActive('/mundial') ? 'text-wc-gold font-bold border-l-2 border-wc-gold pl-2' : 'text-slate-350 hover:text-wc-gold'}`}>El Mundial</a>
        
        {userProfile?.role === 'admin' && (
          <a href="/admin" class={`py-2 font-semibold transition-colors flex items-center gap-1.5 ${isActive('/admin') ? 'text-yellow-400 font-bold border-l-2 border-yellow-450 pl-2' : 'text-wc-gold hover:text-yellow-400'}`}>
            <Shield className="w-4.5 h-4.5 text-wc-gold animate-pulse-subtle" strokeWidth={2.5} />
            Administrador
          </a>
        )}

        <div class="pt-3 border-t border-wc-border/50 flex flex-col gap-2">
          {userProfile ? (
            <button
              id="logout-btn-mobile"
              class="w-full text-center py-3 px-4 rounded-xl text-sm font-bold bg-slate-800 hover:bg-red-950/40 hover:text-red-400 border border-slate-700 hover:border-red-900/50 transition-all duration-200"
            >
              Cerrar Sesión
            </button>
          ) : (
            <>
              <a
                href="/login"
                class="w-full text-center py-2.5 px-4 rounded-xl text-xs font-bold text-slate-300 bg-slate-800 hover:bg-slate-700 transition-colors"
              >
                Ingresar
              </a>
              <a
                href="/register"
                class="w-full text-center py-2.5 px-4 rounded-xl text-xs font-bold bg-gradient-to-r from-wc-gold to-amber-500 hover:from-yellow-400 hover:to-amber-400 text-slate-950 shadow-md shadow-wc-gold/5 transition-all"
              >
                Registrar
              </a>
            </>
          )}
        </div>
      </div>
    </div>

    <!-- Main Content Area -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-wc-border bg-wc-dark/85 py-8 text-slate-400 text-sm mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex flex-col items-center md:items-start gap-1">
          <p class="flex items-center gap-2 font-medium text-slate-200 text-base">
            <Logo mode="horizontal" size="small" />
          </p>
          <p class="text-xs text-slate-500 text-center md:text-left">
            Para uso de amigos y organizadores. Desarrollado por <span class="text-slate-400 font-medium">Alirio Isea</span>.
            <span class="mx-2 text-slate-700 hidden sm:inline">|</span>
            <br class="sm:hidden" />
            <a href="/privacidad" class="text-slate-500 hover:text-wc-gold underline transition-colors mt-1 sm:mt-0 inline-block">Política de Privacidad</a>
          </p>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-xs text-slate-500 font-bold uppercase tracking-wider font-sports">Soporte y Contacto:</span>
          <a
            href="https://wa.me/qr/5GVLWHJQDPBUF1"
            target="_blank"
            rel="noopener noreferrer"
            class="p-2.5 rounded-xl bg-slate-800/40 hover:bg-slate-800 border border-slate-700/60 hover:border-slate-600 transition-all duration-200 text-slate-400 hover:text-green-500 hover:-translate-y-0.5 shadow-sm"
            title="Contactar por WhatsApp"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.704 1.459h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/alirioi/"
            target="_blank"
            rel="noopener noreferrer"
            class="p-2.5 rounded-xl bg-slate-800/40 hover:bg-slate-800 border border-slate-700/60 hover:border-slate-600 transition-all duration-200 text-slate-400 hover:text-pink-500 hover:-translate-y-0.5 shadow-sm"
            title="Seguir en Instagram"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 0C8.74 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051C.014 8.333 0 8.74 0 12s.014 3.333.072 4.617c.2 4.36 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.257 0 3.664-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.257-.014-3.664-.073-4.948-.2-4.354-2.617-6.78-6.979-6.98C15.664.014 15.257 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.074 3.756.172 5.502 1.946 5.673 5.673.059 1.265.074 1.645.074 4.85s-.015 3.585-.074 4.85c-.172 3.756-1.946 5.502-5.673 5.673-1.265.059-1.645.074-4.85.074s-3.585-.015-4.85-.074c-3.756-.172-5.502-1.946-5.673-5.673-.059-1.265-.074-1.645-.074-4.85s.015-3.585.074-4.85c.172-3.756 1.946-5.502 5.673-5.673 1.265-.059 1.645-.074 4.85-.074zm0 3.678c-3.405 0-6.162 2.76-6.162 6.162 0 3.405 2.76 6.162 6.162 6.162 3.405 0 6.162-2.76 6.162-6.162 0-3.405-2.76-6.162-6.162-6.162zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405c0 .795-.646 1.44-1.44 1.44-.795 0-1.44-.645-1.44-1.44 0-.794.645-1.439 1.44-1.439.793-.001 1.44.645 1.44 1.439z"/>
            </svg>
          </a>
        </div>
      </div>
    </footer>

    <!-- Cookie Consent Banner -->
    <div
      id="cookie-consent-banner"
      class="hidden fixed bottom-4 left-4 right-4 md:left-auto md:max-w-md md:bottom-6 md:right-6 z-50 bg-slate-950/95 backdrop-blur-md border border-wc-border/60 p-5 rounded-2xl shadow-2xl flex-col gap-4 transform translate-y-0 transition-all duration-300 animate-slide-up"
    >
      <div class="flex items-start gap-3">
        <div class="p-2 rounded-lg bg-wc-gold/10 text-wc-gold mt-0.5">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
        </div>
        <div class="flex-grow">
          <h4 class="font-sports tracking-wider text-transparent bg-clip-text bg-gradient-to-r from-wc-gold to-amber-400 text-lg font-black leading-none mb-1">
            Uso de Cookies y Privacidad
          </h4>
          <p class="text-xs text-slate-300 leading-relaxed">
            Utilizamos cookies esenciales para el funcionamiento del sitio y cookies analíticas para medir visitas de forma anónima (Google Analytics). Puedes leer más en nuestra 
            <a href="/privacidad" class="underline text-wc-gold hover:text-yellow-400 transition-colors">Política de Privacidad</a>.
          </p>
        </div>
      </div>
      <div class="flex items-center justify-end gap-3 pt-2">
        <button
          id="cookie-reject-btn"
          class="px-3.5 py-1.5 rounded-lg text-xs font-semibold bg-slate-900 hover:bg-slate-800 text-slate-300 border border-slate-700 transition-colors"
        >
          Rechazar todo
        </button>
        <button
          id="cookie-accept-btn"
          class="px-4 py-1.5 rounded-lg text-xs font-bold bg-gradient-to-r from-wc-gold to-amber-500 hover:from-yellow-400 hover:to-amber-400 text-slate-950 transition-all shadow-md shadow-wc-gold/10 hover:shadow-wc-gold/20"
        >
          Aceptar todo
        </button>
      </div>
    </div>

    <script>
      // Theme Toggle Logic
      const themeToggleBtn = document.getElementById('theme-toggle');
      const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');
      const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');

      function updateThemeIcons() {
        const isLight = document.documentElement.classList.contains('light');
        if (isLight) {
          themeToggleLightIcon?.classList.add('hidden');
          themeToggleDarkIcon?.classList.remove('hidden');
        } else {
          themeToggleLightIcon?.classList.remove('hidden');
          themeToggleDarkIcon?.classList.add('hidden');
        }
      }

      // Initial run to show correct icon
      updateThemeIcons();

      themeToggleBtn?.addEventListener('click', () => {
        const currentlyLight = document.documentElement.classList.toggle('light');
        localStorage.setItem('theme', currentlyLight ? 'light' : 'dark');
        updateThemeIcons();
      });

      // Header autohide scroll behavior
      let lastScrollY = window.scrollY;
      const headerEl = document.getElementById('main-header');
      const mobileMenuEl = document.getElementById('mobile-menu');

      window.addEventListener('scroll', () => {
        // Do not hide the header if the mobile menu drawer is open
        if (mobileMenuEl && !mobileMenuEl.classList.contains('hidden')) {
          return;
        }

        const currentScrollY = window.scrollY;
        
        // Always show header near the top of the page
        if (currentScrollY < 100) {
          headerEl?.classList.remove('-translate-y-full');
          return;
        }

        if (currentScrollY > lastScrollY) {
          // Scrolling down -> hide header
          headerEl?.classList.add('-translate-y-full');
        } else {
          // Scrolling up -> show header
          headerEl?.classList.remove('-translate-y-full');
        }
        
        lastScrollY = currentScrollY;
      });

      // Toggle de menú móvil
      const toggleBtn = document.getElementById('mobile-menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamburgerIcon = document.getElementById('hamburger-icon');
      const closeIcon = document.getElementById('close-icon');

      toggleBtn?.addEventListener('click', () => {
        const isHidden = mobileMenu?.classList.toggle('hidden');
        if (isHidden) {
          hamburgerIcon?.classList.remove('hidden');
          closeIcon?.classList.add('hidden');
        } else {
          hamburgerIcon?.classList.add('hidden');
          closeIcon?.classList.remove('hidden');
        }
      });

      // Manejo de Cerrar Sesión (para ambos botones)
      const handleLogout = async () => {
        try {
          const response = await fetch('/api/auth/logout', { method: 'POST' });
          if (response.ok) {
            window.location.href = '/';
          } else {
            console.error('Error al cerrar sesión');
          }
        } catch (e) {
          console.error('Error de red', e);
        }
      };

      document.getElementById('logout-btn')?.addEventListener('click', handleLogout);
      document.getElementById('logout-btn-mobile')?.addEventListener('click', handleLogout);

      // Cookie Consent Banner logic
      const banner = document.getElementById('cookie-consent-banner');
      const acceptBtn = document.getElementById('cookie-accept-btn');
      const rejectBtn = document.getElementById('cookie-reject-btn');

      function loadGoogleAnalytics() {
        if (document.getElementById('ga-gtag-script')) return;

        const script = document.createElement('script');
        script.id = 'ga-gtag-script';
        script.async = true;
        script.src = 'https://www.googletagmanager.com/gtag/js?id=G-J1JCNSPG92';
        document.head.appendChild(script);

        const inlineScript = document.createElement('script');
        inlineScript.id = 'ga-gtag-inline';
        inlineScript.innerHTML = `
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-J1JCNSPG92');
          window.gtag = gtag;
        `;
        document.head.appendChild(inlineScript);
      }

      if (banner && acceptBtn && rejectBtn) {
        const consent = localStorage.getItem('cookie-consent');
        if (!consent) {
          banner.classList.remove('hidden');
          banner.classList.add('flex');
        }

        acceptBtn.addEventListener('click', () => {
          localStorage.setItem('cookie-consent', 'accepted');
          loadGoogleAnalytics();
          banner.classList.add('hidden');
          banner.classList.remove('flex');
        });

        rejectBtn.addEventListener('click', () => {
          localStorage.setItem('cookie-consent', 'rejected');
          banner.classList.add('hidden');
          banner.classList.remove('flex');
        });
      }

      // Scroll to Top Logic
      const scrollToTopBtn = document.getElementById('scroll-to-top');

      window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
          scrollToTopBtn?.classList.remove('translate-y-16', 'opacity-0', 'scale-75', 'pointer-events-none');
          scrollToTopBtn?.classList.add('translate-y-0', 'opacity-100', 'scale-100', 'pointer-events-auto');
        } else {
          scrollToTopBtn?.classList.add('translate-y-16', 'opacity-0', 'scale-75', 'pointer-events-none');
          scrollToTopBtn?.classList.remove('translate-y-0', 'opacity-100', 'scale-100', 'pointer-events-auto');
        }
      });

      scrollToTopBtn?.addEventListener('click', () => {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      });
    </script>

    <!-- Go to Top Button -->
    <button
      id="scroll-to-top"
      class="fixed bottom-24 right-6 z-50 flex items-center justify-center w-12 h-12 rounded-full bg-wc-card/85 hover:bg-wc-gold text-slate-100 hover:text-slate-950 border border-wc-border/80 hover:border-wc-gold shadow-lg hover:shadow-wc-gold/30 backdrop-blur-md transform translate-y-16 opacity-0 scale-75 pointer-events-none transition-all duration-300 focus:outline-none"
      aria-label="Ir arriba"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
      </svg>
    </button>
  </body>
</html>
