---
export const prerender = false;
import MainLayout from '../layouts/MainLayout.astro';
import PaymentBreakdown from '../components/ui/PaymentBreakdown.astro';
import RegisterPaymentSection from '../components/islands/RegisterPaymentSection';
import { UserPlus, Lock } from 'lucide-react';
import Logo from '../components/Logo.astro';

// Si el usuario ya está autenticado y tiene cupos aprobados, se le redirige al dashboard.
const user = Astro.locals.user;
const profile = Astro.locals.profile;
const isApproved = Astro.locals.isApproved;

if (user) {
  if (isApproved || profile?.role === 'admin') {
    return Astro.redirect('/dashboard');
  } else {
    return Astro.redirect('/pending');
  }
}

// Calcular límite de inscripciones (2 días antes del mundial)
const FIRST_MATCH_TIME = new Date('2026-06-11T22:30:00Z');
const REGISTRATION_DEADLINE = new Date(FIRST_MATCH_TIME.getTime() - 2 * 24 * 60 * 60 * 1000);
const isRegistrationClosed = Date.now() >= REGISTRATION_DEADLINE.getTime();
---

<MainLayout title="Registro" description="Únete a la Quiniela Mundial 2026. Crea tu cuenta, registra tu cupo y empieza a demostrar tus conocimientos futbolísticos para ganar el pote acumulado.">
  <div class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-4 py-12 sm:px-6 lg:px-8 bg-radial-gradient">
    <div class="max-w-xl w-full space-y-8 bg-wc-card/65 backdrop-blur-md p-8 rounded-2xl border border-wc-border shadow-2xl relative overflow-hidden">
      <!-- Decorative gradients -->
      <div class="absolute -top-10 -right-10 w-40 h-40 bg-wc-gold/10 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-wc-blue/10 rounded-full blur-3xl pointer-events-none"></div>

      <div class="text-center relative flex flex-col items-center">
        <Logo mode="vertical" size="large" className="mb-2 animate-pulse-subtle" />
        <h2 class="mt-4 text-sm text-slate-350 font-medium">
          Crea tu cuenta, registra tu primer cupo y comienza a pronosticar.
        </h2>
      </div>

      {isRegistrationClosed ? (
        <div class="mt-8 space-y-6 bg-wc-dark p-6 rounded-xl border border-wc-border text-center flex flex-col items-center">
          <Lock className="w-12 h-12 text-slate-500 mb-2" strokeWidth={2.5} />
          <h2 class="text-lg font-sports font-bold text-wc-gold tracking-wider">Inscripciones Cerradas</h2>
          <p class="text-xs text-slate-400 mt-2">
            El registro de nuevos usuarios y la compra de cupos finalizaron el 9 de Junio de 2026 a las 22:30 UTC (48 horas antes del inicio del torneo).
          </p>
          <div class="pt-4">
            <a href="/" class="inline-block py-2.5 px-6 rounded-lg bg-wc-card hover:bg-wc-card/85 text-slate-200 text-xs font-semibold border border-wc-border transition-all">
              Volver al Inicio
            </a>
          </div>
        </div>
      ) : (
        <form id="register-form" class="mt-8 space-y-6 relative" enctype="multipart/form-data">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div class="space-y-4 md:col-span-2">
              <h2 class="text-sm font-sports font-bold uppercase tracking-wider text-slate-200 border-b border-wc-border pb-2.5">
                Información de la Cuenta
              </h2>
            </div>

            <div>
              <label for="fullName" class="block text-xs font-bold uppercase tracking-wider text-slate-300 mb-1.5">
                Nombre Completo <span class="text-red-500">*</span>
              </label>
              <input
                id="fullName"
                name="fullName"
                type="text"
                required
                class="w-full px-4 py-3 rounded-xl bg-wc-dark border border-wc-border text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-wc-gold/50 focus:border-wc-gold transition-all duration-200 text-sm font-medium"
                placeholder="Nombre Apellido"
              />
            </div>

            <div>
              <label for="displayName" class="block text-xs font-bold uppercase tracking-wider text-slate-300 mb-1.5">
                Apodo para la Quiniela (Cupo #1) <span class="text-red-500">*</span>
              </label>
              <input
                id="displayName"
                name="displayName"
                type="text"
                required
                class="w-full px-4 py-3 rounded-xl bg-wc-dark border border-wc-border text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-wc-gold/50 focus:border-wc-gold transition-all duration-200 text-sm font-medium"
                placeholder="Ej: Campeón #1"
              />
              <p class="text-xs text-slate-500 mt-1.5 leading-relaxed">Se mostrará públicamente en la clasificación. Puedes usar un seudónimo si prefieres ocultar tu identidad real.</p>
            </div>

            <div>
              <label for="email" class="block text-xs font-bold uppercase tracking-wider text-slate-300 mb-1.5">
                Correo Electrónico <span class="text-red-500">*</span>
              </label>
              <input
                id="email"
                name="email"
                type="email"
                required
                class="w-full px-4 py-3 rounded-xl bg-wc-dark border border-wc-border text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-wc-gold/50 focus:border-wc-gold transition-all duration-200 text-sm font-medium"
                placeholder="tu@correo.com"
              />
            </div>

            <div>
              <label for="phone" class="block text-xs font-bold uppercase tracking-wider text-slate-300 mb-1.5">
                Teléfono (WhatsApp)
              </label>
              <input
                id="phone"
                name="phone"
                type="tel"
                class="w-full px-4 py-3 rounded-xl bg-wc-dark border border-wc-border text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-wc-gold/50 focus:border-wc-gold transition-all duration-200 text-sm font-medium"
                placeholder="Ej: +58 412 1234567 (Opcional)"
              />
              <p class="text-xs text-slate-500 mt-1.5 leading-relaxed">Si dejas esto en blanco, por favor mantente muy atento a tu correo electrónico, ya que será nuestra única vía de contacto si resultas ganador o hay algún problema con tu cuenta.</p>
            </div>

            <div>
              <label for="birthDate" class="block text-xs font-bold uppercase tracking-wider text-slate-300 mb-1.5">
                Fecha de Nacimiento <span class="text-red-500">*</span>
              </label>
              <input
                id="birthDate"
                name="birthDate"
                type="date"
                required
                class="w-full px-4 py-3 rounded-xl bg-wc-dark border border-wc-border text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-wc-gold/50 focus:border-wc-gold transition-all duration-200 text-sm font-medium"
              />
              <p class="text-xs text-slate-500 mt-1.5 leading-relaxed">Debes ser mayor de 18 años para participar en la quiniela.</p>
            </div>

            <div>
              <label for="password" class="block text-xs font-bold uppercase tracking-wider text-slate-300 mb-1.5">
                Contraseña <span class="text-red-500">*</span>
              </label>
              <input
                id="password"
                name="password"
                type="password"
                required
                minlength="6"
                class="w-full px-4 py-3 rounded-xl bg-wc-dark border border-wc-border text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-wc-gold/50 focus:border-wc-gold transition-all duration-200 text-sm font-medium"
                placeholder="Mínimo 6 caracteres"
              />
              <p class="text-xs text-slate-500 mt-1.5 leading-relaxed">Para acceder a tu panel y modificar tus pronósticos.</p>
            </div>
          </div>

          <div class="space-y-4 pt-4">
            <h2 class="text-sm font-sports font-bold uppercase tracking-wider text-slate-200 border-b border-wc-border pb-2.5">
              Detalles de Pago y Comprobante
            </h2>
            
            <!-- Componente de desglose -->
            <PaymentBreakdown />

            <!-- Sección Reactiva de Método de Pago y Comprobante -->
            <RegisterPaymentSection client:load />
          </div>

          <!-- Checkbox de aceptación de reglamento -->
          <div class="flex items-start gap-3 bg-wc-dark/30 p-3.5 rounded-xl border border-wc-border/30">
            <input
              id="acceptRules"
              name="acceptRules"
              type="checkbox"
              required
              class="w-4 h-4 rounded border-wc-border bg-wc-dark text-wc-gold focus:ring-wc-gold focus:ring-offset-wc-dark mt-0.5 cursor-pointer animate-pulse-subtle"
            />
            <label for="acceptRules" class="text-xs text-slate-300 leading-relaxed select-none cursor-pointer">
              He leído y acepto en su totalidad las <a href="/faq" target="_blank" class="font-bold text-wc-gold hover:underline">Reglas e Instrucciones de la Quiniela</a>, y entiendo que una vez formalizada mi inscripción <strong>no se realizarán reembolsos</strong> bajo ninguna circunstancia.
            </label>
          </div>

          <div id="error-message" class="hidden p-3.5 rounded-lg bg-red-950/40 border border-red-900/50 text-red-400 text-xs font-semibold mb-4 mt-2">
          </div>

          <div class="pt-2">
            <button
              type="submit"
              id="submit-btn"
              class="w-full py-4 px-4 rounded-xl bg-gradient-to-r from-wc-gold to-amber-500 hover:from-yellow-400 hover:to-amber-400 text-slate-950 shadow-lg shadow-wc-gold/15 hover:shadow-wc-gold/30 hover:-translate-y-0.5 transition-all duration-200 flex items-center justify-center gap-2 group font-sports font-black text-lg tracking-wider"
            >
              <span>Crear cuenta y registrar cupo</span>
              <UserPlus className="w-5 h-5 text-slate-950 group-hover:scale-110 transition-all" strokeWidth={2.5} />
            </button>
          </div>
        </form>
      )}

      <div class="text-center text-sm text-slate-400 border-t border-wc-border pt-6">
        ¿Ya tienes una cuenta?
        <a href="/login" class="font-bold text-transparent bg-clip-text bg-gradient-to-r from-wc-gold to-amber-500 hover:opacity-90 transition-opacity ml-1">
          Inicia sesión aquí
        </a>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('register-form') as HTMLFormElement;
    const errorDiv = document.getElementById('error-message');
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const USER_PLUS_SVG = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-slate-950 group-hover:scale-110 transition-all"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><line x1="19" x2="19" y1="8" y2="14"></line><line x1="22" x2="16" y1="11" y2="11"></line></svg>`;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!errorDiv || !submitBtn) return;

      errorDiv.classList.add('hidden');

      // Validar edad >= 18 en el cliente
      const birthDateInput = document.getElementById('birthDate') as HTMLInputElement;
      if (birthDateInput) {
        const birthDateVal = new Date(birthDateInput.value);
        if (isNaN(birthDateVal.getTime())) {
          errorDiv.textContent = 'Por favor, ingresa una fecha de nacimiento válida.';
          errorDiv.classList.remove('hidden');
          return;
        }
        const today = new Date();
        let age = today.getFullYear() - birthDateVal.getFullYear();
        const m = today.getMonth() - birthDateVal.getMonth();
        if (m < 0 || (m === 0 && today.getDate() < birthDateVal.getDate())) {
          age--;
        }
        if (age < 18) {
          errorDiv.textContent = 'Debes ser mayor de 18 años para participar en la quiniela.';
          errorDiv.classList.remove('hidden');
          return;
        }
      }

      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span>Procesando registro...</span>';

      const formData = new FormData(form);

      try {
        const response = await fetch('/api/auth/register', {
          method: 'POST',
          body: formData
        });

        const data = await response.json();

        if (response.ok) {
          // El registro fue exitoso y el endpoint setea las cookies de sesión,
          // redirigimos a la página pendiente
          window.location.href = '/pending';
        } else {
          errorDiv.textContent = data.error || 'Error al completar el registro';
          errorDiv.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.innerHTML = `<span>Crear cuenta y registrar cupo</span>${USER_PLUS_SVG}`;
        }
      } catch (err) {
        errorDiv.textContent = 'Error de conexión. Inténtalo de nuevo.';
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.innerHTML = `<span>Crear cuenta y registrar cupo</span>${USER_PLUS_SVG}`;
      }
    });
  </script>
  <style is:global>
    /* Soporte de modo oscuro para input de fecha de nacimiento */
    input[type="date"] {
      color-scheme: dark !important;
    }
    input[type="date"]::-webkit-calendar-picker-indicator {
      filter: brightness(0) invert(1) !important;
      opacity: 0.7;
      cursor: pointer;
    }
    input[type="date"]::-webkit-calendar-picker-indicator:hover {
      opacity: 1;
    }
  </style>
</MainLayout>
