---
export const prerender = false;
import MainLayout from '../../layouts/MainLayout.astro';
import PredictionsDashboard from '../../components/islands/PredictionsDashboard';
import { ShieldAlert } from 'lucide-react';

const profile = Astro.locals.profile;
const entries = Astro.locals.entries || [];
const approvedEntries = entries.filter(e => e.status === 'approved');

// Si no hay cupos aprobados, redirigir a pending (a menos que sea admin)
if (approvedEntries.length === 0 && profile?.role !== 'admin') {
  return Astro.redirect('/pending');
}
---

<MainLayout title="Mis Pronósticos" userProfile={profile}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-10">
    
    {/* Cabecera */}
    <div class="text-center space-y-3">
      <h1 class="text-4xl sm:text-5xl font-black font-sports tracking-wider text-white uppercase bg-clip-text bg-gradient-to-r from-wc-gold to-amber-500">
        Mis Pronósticos
      </h1>
      <p class="text-slate-400 max-w-2xl mx-auto text-sm sm:text-base leading-relaxed">
        Gestiona tus cupos, realiza tus predicciones y sigue el rendimiento de tus jugadas en tiempo real.
      </p>
    </div>

    {/* Dashboard Island */}
    <PredictionsDashboard client:load userEntries={approvedEntries} />

    {/* Disclaimer General */}
    <div class="p-4 rounded-2xl bg-wc-dark/50 border border-wc-border text-center flex items-center justify-center gap-2.5 max-w-2xl mx-auto">
      <ShieldAlert className="w-5 h-5 text-slate-500 shrink-0 animate-pulse" />
      <p class="text-xs text-slate-450 leading-relaxed">
        Recuerda que tus cambios se guardan automáticamente por partido. Las predicciones cierran estrictamente 2 horas antes de cada juego.
      </p>
    </div>

  </div>
</MainLayout>
