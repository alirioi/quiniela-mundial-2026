---
export const prerender = false;
import MainLayout from '../../layouts/MainLayout.astro';
import LivePredictions from '../../components/islands/LivePredictions';

// Obtener datos del middleware
const user = Astro.locals.user;
const profile = Astro.locals.profile;
const isApproved = Astro.locals.isApproved;

// Si no está logueado, redirigir a index
if (!user) {
  return Astro.redirect('/');
}

// Si no está aprobado, redirigir a pending (a menos que sea admin)
if (!isApproved && profile?.role !== 'admin') {
  return Astro.redirect('/pending');
}
---

<MainLayout title="Pronósticos En Vivo" userProfile={profile}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <LivePredictions client:load />
  </div>
</MainLayout>
