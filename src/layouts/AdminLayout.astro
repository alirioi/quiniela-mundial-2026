---
import MainLayout from './MainLayout.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;

// Obtener datos de locales (inyectados por el middleware)
const profile = Astro.locals.profile;

// Verificamos en el middleware que sea admin, pero aquí mostramos su perfil
const activePath = Astro.url.pathname;
---

<MainLayout title={`Panel Admin - ${title}`} userProfile={profile}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Admin Header -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 border-b border-slate-800/80 pb-6 mb-8">
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-white flex items-center gap-2.5">
          <span>🛡️</span> Panel de Administración
        </h1>
        <p class="text-xs text-slate-400 mt-1">
          Gestiona los pagos de los usuarios, registra marcadores oficiales y administra las fases del torneo.
        </p>
      </div>
      
      <!-- Subnavegación de Admin -->
      <nav class="flex items-center gap-2 p-1 bg-slate-900/60 border border-slate-800/80 rounded-2xl w-fit">
        <a
          href="/admin"
          class={`px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider transition-colors ${
            activePath === '/admin'
              ? 'bg-gradient-to-r from-emerald-500 to-teal-600 text-slate-950 shadow-md shadow-emerald-950/20'
              : 'text-slate-400 hover:text-slate-200'
          }`}
        >
          💳 Cupos y Pagos
        </a>
        <a
          href="/admin/matches"
          class={`px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider transition-colors ${
            activePath === '/admin/matches'
              ? 'bg-gradient-to-r from-emerald-500 to-teal-600 text-slate-950 shadow-md shadow-emerald-950/20'
              : 'text-slate-400 hover:text-slate-200'
          }`}
        >
          ⚽ Marcadores
        </a>
        <a
          href="/admin/phases"
          class={`px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider transition-colors ${
            activePath === '/admin/phases'
              ? 'bg-gradient-to-r from-emerald-500 to-teal-600 text-slate-950 shadow-md shadow-emerald-950/20'
              : 'text-slate-400 hover:text-slate-200'
          }`}
        >
          ⚙️ Fases
        </a>
      </nav>
    </div>

    <!-- Área de Contenido del Panel -->
    <div class="relative">
      <slot />
    </div>
  </div>
</MainLayout>
