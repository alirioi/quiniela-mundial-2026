---
import '../styles/global.css';
import { Trophy, Shield } from 'lucide-react';

interface Props {
  title: string;
  description?: string;
  userProfile?: {
    full_name: string;
    role: string;
    email: string;
  } | null;
}

const { title, description = 'Quiniela del Mundial 2026', userProfile } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} | Quiniela Mundial 2026</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <style>
      body {
        font-family: 'Outfit', sans-serif;
      }
      .font-sports {
        font-family: 'Bebas Neue', sans-serif;
        letter-spacing: 0.05em;
      }
    </style>
  </head>
  <body class="bg-wc-dark text-slate-100 min-h-screen flex flex-col selection:bg-wc-gold selection:text-slate-950 bg-radial-gradient">
    <!-- Premium Header -->
    <header class="border-b border-wc-border/80 bg-wc-card/40 backdrop-blur-md sticky top-0 z-40">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href={userProfile ? "/dashboard" : "/"} class="flex items-center space-x-2 group">
          <Trophy className="w-5.5 h-5.5 text-wc-gold transition-transform group-hover:scale-110 duration-200" strokeWidth={2.5} />
          <span class="font-sports font-black tracking-wider text-transparent bg-clip-text bg-gradient-to-r from-wc-red via-wc-gold to-wc-green text-2xl group-hover:opacity-90 transition-opacity">
            Quiniela 2026
          </span>
        </a>

        <nav class="hidden md:flex items-center space-x-6 text-sm font-medium">
          {userProfile && (
            <>
              <a href="/dashboard" class="text-slate-300 hover:text-wc-gold transition-colors">Dashboard</a>
              <a href="/my-entries" class="text-slate-300 hover:text-wc-gold transition-colors">Mis Cupos</a>
            </>
          )}
          <a href="/faq" class="text-slate-300 hover:text-wc-gold transition-colors">Reglas y FAQ</a>
          {userProfile?.role === 'admin' && (
            <a href="/admin" class="text-wc-gold hover:text-yellow-400 font-semibold transition-colors flex items-center gap-1.5">
              <Shield className="w-4.5 h-4.5 text-wc-gold animate-pulse-subtle" strokeWidth={2.5} />
              Admin
            </a>
          )}
        </nav>

        <div class="flex items-center space-x-2 sm:space-x-4">
          {userProfile ? (
            <div class="flex items-center space-x-2 sm:space-x-4">
              <span class="hidden lg:inline text-xs text-slate-400 font-medium">
                Hola, <span class="text-slate-200">{userProfile.full_name}</span>
              </span>
              <button
                id="logout-btn"
                class="hidden sm:inline-block px-3.5 py-1.5 rounded-lg text-xs font-semibold bg-slate-800 hover:bg-red-950/40 hover:text-red-400 border border-slate-700 hover:border-red-900/50 transition-all duration-200"
              >
                Cerrar Sesión
              </button>
            </div>
          ) : (
            <a
              href="/login"
              class="hidden sm:inline-block px-4 py-2 rounded-lg text-sm font-semibold bg-gradient-to-r from-wc-gold to-amber-500 hover:from-yellow-400 hover:to-amber-400 text-slate-950 shadow-lg shadow-wc-gold/10 hover:shadow-wc-gold/25 transition-all duration-200"
            >
              Iniciar Sesión
            </a>
          )}

          <!-- Hamburger Button -->
          <button
            id="mobile-menu-toggle"
            class="md:hidden p-2 rounded-xl text-slate-400 hover:text-white bg-slate-800/40 hover:bg-slate-800 border border-slate-700/60 transition-all focus:outline-none"
            aria-label="Menú de navegación"
          >
            <svg id="hamburger-icon" class="w-5.5 h-5.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="close-icon" class="w-5.5 h-5.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Mobile Menu (hidden by default) -->
    <div
      id="mobile-menu"
      class="hidden md:hidden border-b border-wc-border/90 bg-wc-card/95 backdrop-blur-lg transition-all duration-300"
    >
      <div class="px-4 py-4 space-y-3 font-medium text-sm">
        {userProfile && (
          <div class="pb-3 border-b border-wc-border/50">
            <span class="text-xs text-slate-400 block mb-1">Sesión iniciada como:</span>
            <span class="text-slate-200 font-bold block">{userProfile.full_name}</span>
            <span class="text-xs text-slate-500 block">{userProfile.email}</span>
          </div>
        )}

        {userProfile && (
          <>
            <a href="/dashboard" class="block py-2 text-slate-350 hover:text-wc-gold transition-colors">Dashboard</a>
            <a href="/my-entries" class="block py-2 text-slate-350 hover:text-wc-gold transition-colors">Mis Cupos</a>
          </>
        )}
        <a href="/faq" class="block py-2 text-slate-350 hover:text-wc-gold transition-colors">Reglas y FAQ</a>
        
        {userProfile?.role === 'admin' && (
          <a href="/admin" class="py-2 text-wc-gold hover:text-yellow-400 font-semibold transition-colors flex items-center gap-1.5">
            <Shield className="w-4.5 h-4.5 text-wc-gold animate-pulse-subtle" strokeWidth={2.5} />
            Administrador
          </a>
        )}

        <div class="pt-3 border-t border-wc-border/50 flex flex-col gap-2">
          {userProfile ? (
            <button
              id="logout-btn-mobile"
              class="w-full text-center py-2 px-4 rounded-xl text-xs font-bold bg-slate-800 hover:bg-red-950/40 hover:text-red-400 border border-slate-700 hover:border-red-900/50 transition-all duration-200"
            >
              Cerrar Sesión
            </button>
          ) : (
            <a
              href="/login"
              class="w-full text-center py-2.5 px-4 rounded-xl text-xs font-bold bg-gradient-to-r from-wc-gold to-amber-500 hover:from-yellow-400 hover:to-amber-400 text-slate-950 shadow-md shadow-wc-gold/5 transition-all text-center"
            >
              Iniciar Sesión
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- Main Content Area -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-wc-border bg-wc-dark/85 py-8 text-slate-400 text-sm mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex flex-col items-center md:items-start gap-1">
          <p class="flex items-center gap-2 font-medium text-slate-200 text-base">
            <Trophy className="w-5 h-5 text-wc-gold" strokeWidth={2.5} />
            <span class="font-sports tracking-wider uppercase">Quiniela Mundial 2026</span>
          </p>
          <p class="text-xs text-slate-500">
            Para uso de amigos y organizadores. Desarrollado por <span class="text-slate-400 font-medium">Alirio Isea</span>.
          </p>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-xs text-slate-500 font-bold uppercase tracking-wider font-sports">Soporte y Contacto:</span>
          <a
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="p-2.5 rounded-xl bg-slate-800/40 hover:bg-slate-800 border border-slate-700/60 hover:border-slate-600 transition-all duration-200 text-slate-400 hover:text-green-500 hover:-translate-y-0.5 shadow-sm"
            title="Contactar por WhatsApp"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M12.004 2C6.48 2 2.001 6.482 2 12.005c.002 1.848.508 3.654 1.466 5.234l-1.56 5.698 5.827-1.528A9.957 9.957 0 0 0 12.004 22c5.522 0 10.002-4.48 10.002-10.002C22.006 6.48 17.526 2 12.004 2zm0 18.002c-1.66 0-3.284-.442-4.71-1.282l-.337-.2-.3.078-3.428.9 1.077-3.238-.22-.35a8.005 8.005 0 0 1-1.127-4.14C2.96 7.424 6.84 3.543 11.69 3.543c4.85 0 8.73 3.882 8.73 8.733 0 4.85-3.88 8.731-8.73 8.731zm4.78-6.52c-.26-.13-1.54-.76-1.78-.85-.24-.09-.42-.13-.59.13-.18.27-.69.87-.85 1.05-.16.18-.32.2-.58.07a7.35 7.35 0 0 1-2.16-1.33c-.7-.62-1.18-1.38-1.31-1.64-.14-.26-.02-.4.11-.53.12-.11.26-.3.39-.45.13-.15.17-.25.26-.42.09-.17.04-.32-.02-.45-.07-.13-.59-1.42-.81-1.95-.21-.52-.43-.45-.59-.46-.15-.01-.32-.01-.49-.01a.94.94 0 0 0-.68.32c-.24.26-.91.89-.91 2.18s.94 2.53 1.07 2.71c.13.18 1.85 2.83 4.49 3.97.63.27 1.12.43 1.51.55.64.2 1.22.17 1.68.1.51-.07 1.54-.63 1.76-1.24.22-.61.22-1.13.15-1.24-.07-.1-.26-.16-.52-.29z"/>
            </svg>
          </a>
          <a
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="p-2.5 rounded-xl bg-slate-800/40 hover:bg-slate-800 border border-slate-700/60 hover:border-slate-600 transition-all duration-200 text-slate-400 hover:text-pink-500 hover:-translate-y-0.5 shadow-sm"
            title="Seguir en Instagram"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
        </div>
      </div>
    </footer>

    <script>
      // Toggle de menú móvil
      const toggleBtn = document.getElementById('mobile-menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamburgerIcon = document.getElementById('hamburger-icon');
      const closeIcon = document.getElementById('close-icon');

      toggleBtn?.addEventListener('click', () => {
        const isHidden = mobileMenu?.classList.toggle('hidden');
        if (isHidden) {
          hamburgerIcon?.classList.remove('hidden');
          closeIcon?.classList.add('hidden');
        } else {
          hamburgerIcon?.classList.add('hidden');
          closeIcon?.classList.remove('hidden');
        }
      });

      // Manejo de Cerrar Sesión (para ambos botones)
      const handleLogout = async () => {
        try {
          const response = await fetch('/api/auth/logout', { method: 'POST' });
          if (response.ok) {
            window.location.href = '/';
          } else {
            console.error('Error al cerrar sesión');
          }
        } catch (e) {
          console.error('Error de red', e);
        }
      };

      document.getElementById('logout-btn')?.addEventListener('click', handleLogout);
      document.getElementById('logout-btn-mobile')?.addEventListener('click', handleLogout);
    </script>
  </body>
</html>
