---
export const prerender = false;
import MainLayout from '../../layouts/MainLayout.astro';
import PredictionsForm from '../../components/islands/PredictionsForm';
import { Trophy, ArrowLeft, Award } from 'lucide-react';

const { phase } = Astro.params;

if (!phase) {
  return Astro.redirect('/dashboard');
}

// Obtener datos del middleware
const user = Astro.locals.user;
const profile = Astro.locals.profile;
const entries = Astro.locals.entries || [];

// Filtrar solo los cupos que estén aprobados (los únicos que pueden pronosticar)
const approvedEntries = entries.filter(e => e.status === 'approved');

// Si no hay cupos aprobados (medida extra de seguridad por si falla el middleware)
if (approvedEntries.length === 0) {
  if (profile?.role === 'admin') {
    return Astro.redirect('/dashboard');
  }
  return Astro.redirect('/pending');
}

// Mapear slug a título bonito
const phaseTitles: Record<string, string> = {
  'grupos': 'Fase de Grupos',
  'dieciseisavos': 'Dieciseisavos de Final',
  'octavos': 'Octavos de Final',
  'cuartos': 'Cuartos de Final',
  'semifinales': 'Semifinales',
  'final': 'Gran Final y 3er Puesto'
};

const pageTitle = phaseTitles[phase] || 'Pronósticos';
---

<MainLayout title={pageTitle} userProfile={profile}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Cabecera de Página -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 border-b border-wc-border pb-6 mb-8">
      <div>
        <div class="flex items-center gap-2">
          <a href="/dashboard" class="text-sm font-bold text-slate-400 hover:text-wc-gold transition-colors flex items-center gap-1.5 font-sports uppercase tracking-wider cursor-pointer">
            <ArrowLeft className="w-5 h-5 text-slate-400 group-hover:text-wc-gold" strokeWidth={2.5} /> Volver al Dashboard
          </a>
        </div>
        <h1 class="text-4xl font-bold uppercase tracking-wider text-white mt-2 flex items-center gap-2.5 font-sports">
          <Trophy className="w-8 h-8 text-wc-gold" strokeWidth={2.5} /> {pageTitle}
        </h1>
        <p class="text-sm sm:text-base text-slate-400 mt-1.5 leading-relaxed">
          Ingresa tus marcadores para cada partido. Recuerda que el pronóstico se bloquea exactamente <strong class="font-bold text-slate-200">2 horas antes</strong> del inicio de cada juego.
        </p>
      </div>

      <!-- Fase Info/Stats -->
      <div class="p-4 bg-wc-card border border-wc-border rounded-2xl flex items-center gap-3">
        <Award className="w-6 h-6 text-wc-gold flex-shrink-0" strokeWidth={2.5} />
        <div class="text-xs text-slate-300">
          <div>Puntaje: <span class="font-bold text-white">Exacto = 3 pts</span> | <span class="font-bold text-white">Parcial = 1 pt</span></div>
          <div class="mt-0.5 text-xs text-slate-400 font-medium">Mismo sistema de puntuación para todo el torneo.</div>
        </div>
      </div>
    </div>

    <!-- Formulario de predicciones (Isla Reactiva) -->
    <PredictionsForm client:load phaseSlug={phase} userEntries={approvedEntries} />
  </div>
</MainLayout>
