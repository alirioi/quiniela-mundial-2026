---
export const prerender = false;
import MainLayout from '../../layouts/MainLayout.astro';
import PredictionsForm from '../../components/islands/PredictionsForm';
import PhaseCountdownBanner from '../../components/islands/PhaseCountdownBanner';
import KnockoutPredictionBracket from '../../components/islands/KnockoutPredictionBracket';
import { Trophy, ArrowLeft, Award } from 'lucide-react';
import { supabaseAdmin } from '../../lib/supabase-server';

const { phase } = Astro.params;

if (!phase) {
  return Astro.redirect('/dashboard');
}

// Obtener datos del middleware
const user = Astro.locals.user;
const profile = Astro.locals.profile;
const entries = Astro.locals.entries || [];

// Filtrar solo los cupos que estén aprobados (los únicos que pueden pronosticar)
const approvedEntries = entries.filter(e => e.status === 'approved');

// Si no hay cupos aprobados (medida extra de seguridad por si falla el middleware)
if (approvedEntries.length === 0) {
  if (profile?.role === 'admin') {
    return Astro.redirect('/dashboard');
  }
  return Astro.redirect('/pending');
}

// Mapear slug a título bonito
const phaseTitles: Record<string, string> = {
  'grupos': 'Fase de Grupos',
  'eliminatoria': 'Fase Eliminatoria',
  'eliminatorias': 'Fase Eliminatoria',
  'dieciseisavos': 'Dieciseisavos de Final',
  'octavos': 'Octavos de Final',
  'cuartos': 'Cuartos de Final',
  'semifinales': 'Semifinales',
  'final': 'Gran Final y 3er Puesto'
};

const pageTitle = phaseTitles[phase] || 'Pronósticos';

// Si es una fase de eliminación, cargar standings para armar la llave
let groupStandings = {};
let thirdPlaces = [];

if (phase !== 'grupos') {
  const { data: matches, error } = await supabaseAdmin
    .from('matches')
    .select(`
      id,
      phase_id,
      home_team,
      away_team,
      match_time,
      home_score,
      away_score,
      status,
      group_name,
      match_number
    `)
    .order('match_time', { ascending: true });

  if (error) {
    console.error('Error fetching matches for knockout standings:', error);
  }

  const matchData = matches || [];

  // Lógica de posiciones (standings) idéntica a la del Dashboard del Mundial
  interface TeamStats {
    team: string;
    group: string;
    pj: number;
    g: number;
    e: number;
    p: number;
    gf: number;
    gc: number;
    dg: number;
    pts: number;
  }

  const statsByGroup: Record<string, Record<string, TeamStats>> = {};

  matchData.forEach(match => {
    if (!match.group_name) return; // Solo fase de grupos
    const group = match.group_name;
    
    if (!statsByGroup[group]) statsByGroup[group] = {};
    if (!statsByGroup[group][match.home_team]) {
      statsByGroup[group][match.home_team] = { team: match.home_team, group, pj: 0, g: 0, e: 0, p: 0, gf: 0, gc: 0, dg: 0, pts: 0 };
    }
    if (!statsByGroup[group][match.away_team]) {
      statsByGroup[group][match.away_team] = { team: match.away_team, group, pj: 0, g: 0, e: 0, p: 0, gf: 0, gc: 0, dg: 0, pts: 0 };
    }

    if ((match.status === 'finished' || match.status === 'live') && match.home_score !== null && match.away_score !== null) {
      const home = statsByGroup[group][match.home_team];
      const away = statsByGroup[group][match.away_team];
      
      home.pj++;
      away.pj++;
      home.gf += match.home_score;
      home.gc += match.away_score;
      away.gf += match.away_score;
      away.gc += match.home_score;

      if (match.home_score > match.away_score) {
        home.g++;
        home.pts += 3;
        away.p++;
      } else if (match.home_score < match.away_score) {
        away.g++;
        away.pts += 3;
        home.p++;
      } else {
        home.e++;
        away.e++;
        home.pts += 1;
        away.pts += 1;
      }
    }
  });

  const finalStandings: Record<string, TeamStats[]> = {};
  const allThirds: TeamStats[] = [];

  Object.keys(statsByGroup).sort().forEach(group => {
    const teams = Object.values(statsByGroup[group]);
    teams.forEach(t => t.dg = t.gf - t.gc);
    
    teams.sort((a, b) => {
      if (b.pts !== a.pts) return b.pts - a.pts;
      if (b.dg !== a.dg) return b.dg - a.dg;
      if (b.gf !== a.gf) return b.gf - a.gf;
      return a.team.localeCompare(b.team);
    });
    
    finalStandings[group] = teams;
    
    if (teams.length >= 3) {
      allThirds.push(teams[2]);
    }
  });

  allThirds.sort((a, b) => {
    if (b.pts !== a.pts) return b.pts - a.pts;
    if (b.dg !== a.dg) return b.dg - a.dg;
    if (b.gf !== a.gf) return b.gf - a.gf;
    if (b.g !== a.g) return b.g - a.g;
    return a.team.localeCompare(b.team);
  });

  groupStandings = finalStandings;
  thirdPlaces = allThirds;
}
---

<MainLayout title={pageTitle} userProfile={profile}>
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Cabecera de Página -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 border-b border-wc-border pb-6 mb-8">
      <div>
        <div class="flex items-center gap-2">
          <a href="/predictions" class="text-sm font-bold text-slate-400 hover:text-wc-gold transition-colors flex items-center gap-1.5 font-sports uppercase tracking-wider cursor-pointer group">
            <ArrowLeft className="w-5 h-5 text-slate-400 group-hover:text-wc-gold" strokeWidth={2.5} /> Volver a Pronósticos
          </a>
        </div>
        <h1 class="text-4xl font-bold uppercase tracking-wider text-white mt-2 flex items-center gap-2.5 font-sports">
          <Trophy className="w-8 h-8 text-wc-gold" strokeWidth={2.5} /> {pageTitle}
        </h1>
        <p class="text-sm sm:text-base text-slate-400 mt-1.5 leading-relaxed">
          {phase === 'grupos' 
            ? "Ingresa tus marcadores para cada partido. Recuerda que el pronóstico se bloquea exactamente 30 minutos antes del inicio de cada juego."
            : "Visualiza los emparejamientos y el camino a la gloria de la fase de eliminación directa."}
        </p>
      </div>

      <!-- Fase Info/Stats -->
      <div class="p-4 bg-wc-card border border-wc-border rounded-2xl flex items-center gap-3">
        <Award className="w-6 h-6 text-wc-gold flex-shrink-0" strokeWidth={2.5} />
        <div class="text-xs text-slate-300">
          <div>Puntaje: <span class="font-bold text-white">Exacto = 3 pts</span> | <span class="font-bold text-white">Parcial = 1 pt</span></div>
          <div class="mt-0.5 text-xs text-slate-400 font-medium">Mismo sistema de puntuación para todo el torneo.</div>
        </div>
      </div>
    </div>

    {phase !== 'grupos' && (
      <PhaseCountdownBanner client:load />
    )}

    <!-- Formulario de predicciones o Llave Eliminatoria (Islas Reactivas) -->
    {phase === 'grupos' ? (
      <PredictionsForm client:load phaseSlug={phase} userEntries={approvedEntries} />
    ) : (
      <KnockoutPredictionBracket client:load groupStandings={groupStandings} thirdPlaces={thirdPlaces} phaseSlug={phase} userEntries={approvedEntries} />
    )}
  </div>
</MainLayout>

