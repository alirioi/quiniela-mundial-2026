---
import MainLayout from '../../layouts/MainLayout.astro';
import PredictionsForm from '../../components/islands/PredictionsForm';

const { phase } = Astro.params;

if (!phase) {
  return Astro.redirect('/dashboard');
}

// Obtener datos del middleware
const user = Astro.locals.user;
const profile = Astro.locals.profile;
const entries = Astro.locals.entries || [];

// Filtrar solo los cupos que estén aprobados (los únicos que pueden pronosticar)
const approvedEntries = entries.filter(e => e.status === 'approved');

// Si no hay cupos aprobados (medida extra de seguridad por si falla el middleware)
if (approvedEntries.length === 0) {
  if (profile?.role === 'admin') {
    return Astro.redirect('/dashboard');
  }
  return Astro.redirect('/pending');
}

// Mapear slug a título bonito
const phaseTitles: Record<string, string> = {
  'grupos': 'Fase de Grupos',
  'dieciseisavos': 'Dieciseisavos de Final',
  'octavos': 'Octavos de Final',
  'cuartos': 'Cuartos de Final',
  'semifinales': 'Semifinales',
  'final': 'Gran Final y 3er Puesto'
};

const pageTitle = phaseTitles[phase] || 'Pronósticos';
---

<MainLayout title={pageTitle} userProfile={profile}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Cabecera de Página -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 border-b border-slate-800/80 pb-6 mb-8">
      <div>
        <div class="flex items-center gap-2">
          <a href="/dashboard" class="text-xs font-semibold text-slate-400 hover:text-emerald-400 transition-colors flex items-center gap-1">
            ⬅️ Volver al Dashboard
          </a>
        </div>
        <h1 class="text-3xl font-extrabold tracking-tight text-white mt-2 flex items-center gap-2">
          <span>🏆</span> {pageTitle}
        </h1>
        <p class="text-xs text-slate-400 mt-1">
          Ingresa tus marcadores para cada partido. Recuerda que el pronóstico se bloquea exactamente **2 horas antes** del inicio de cada juego.
        </p>
      </div>

      <!-- Fase Info/Stats -->
      <div class="p-3 bg-slate-900/40 border border-slate-800/80 rounded-2xl flex items-center gap-3">
        <span class="text-xl">⚽</span>
        <div class="text-xs text-slate-400">
          <div>Puntaje: <span class="font-bold text-slate-200">Exacto = 3 pts</span> | <span class="font-bold text-slate-200">Parcial = 1 pt</span></div>
          <div class="mt-0.5 text-[10px] text-slate-500">Mismo sistema de puntuación para todo el torneo.</div>
        </div>
      </div>
    </div>

    <!-- Formulario de predicciones (Isla Reactiva) -->
    <PredictionsForm client:load phaseSlug={phase} userEntries={approvedEntries} />
  </div>
</MainLayout>
