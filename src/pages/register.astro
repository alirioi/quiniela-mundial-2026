---
import MainLayout from '../layouts/MainLayout.astro';
import PaymentBreakdown from '../components/ui/PaymentBreakdown.astro';
import PaymentUpload from '../components/islands/PaymentUpload';
import { UserPlus, Lock } from 'lucide-react';

// Si el usuario ya está autenticado y tiene cupos aprobados, se le redirige al dashboard.
const user = Astro.locals.user;
const profile = Astro.locals.profile;
const isApproved = Astro.locals.isApproved;

if (user) {
  if (isApproved || profile?.role === 'admin') {
    return Astro.redirect('/dashboard');
  } else {
    return Astro.redirect('/pending');
  }
}

// Calcular límite de inscripciones (2 días antes del mundial)
const FIRST_MATCH_TIME = new Date('2026-06-11T22:30:00Z');
const REGISTRATION_DEADLINE = new Date(FIRST_MATCH_TIME.getTime() - 2 * 24 * 60 * 60 * 1000);
const isRegistrationClosed = Date.now() >= REGISTRATION_DEADLINE.getTime();
---

<MainLayout title="Registro">
  <div class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-4 py-12 sm:px-6 lg:px-8 bg-radial-gradient">
    <div class="max-w-xl w-full space-y-8 bg-slate-900/60 backdrop-blur-md p-8 rounded-2xl border border-slate-800 shadow-2xl relative overflow-hidden">
      <!-- Decorative gradients -->
      <div class="absolute -top-10 -right-10 w-40 h-40 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-indigo-500/10 rounded-full blur-3xl pointer-events-none"></div>

      <div class="text-center relative flex flex-col items-center">
        <UserPlus className="w-12 h-12 text-emerald-400 mb-2 animate-pulse-subtle" />
        <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
          Únete a la <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-300">Quiniela 2026</span>
        </h1>
        <p class="mt-2 text-sm text-slate-400">
          Crea tu cuenta, registra tu primer cupo y comienza a pronosticar.
        </p>
      </div>

      {isRegistrationClosed ? (
        <div class="mt-8 space-y-6 bg-slate-950/80 p-6 rounded-xl border border-amber-900/40 text-center flex flex-col items-center">
          <Lock className="w-12 h-12 text-slate-500 mb-2" />
          <h2 class="text-lg font-bold text-amber-400">Inscripciones Cerradas</h2>
          <p class="text-xs text-slate-400 mt-2">
            El registro de nuevos usuarios y la compra de cupos finalizaron el 9 de Junio de 2026 a las 22:30 UTC (48 horas antes del inicio del torneo).
          </p>
          <div class="pt-4">
            <a href="/" class="inline-block py-2.5 px-6 rounded-lg bg-slate-800 hover:bg-slate-700 text-slate-200 text-xs font-semibold transition-all">
              Volver al Inicio
            </a>
          </div>
        </div>
      ) : (
        <form id="register-form" class="mt-8 space-y-6 relative" enctype="multipart/form-data">
          <div id="error-message" class="hidden p-3.5 rounded-lg bg-red-950/40 border border-red-900/50 text-red-400 text-xs font-semibold">
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div class="space-y-4 md:col-span-2">
              <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-300 border-b border-slate-800/80 pb-2">
                Información de la Cuenta
              </h2>
            </div>

            <div>
              <label for="fullName" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">
                Nombre Completo
              </label>
              <input
                id="fullName"
                name="fullName"
                type="text"
                required
                class="w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all duration-200"
                placeholder="Nombre Apellido"
              />
            </div>

            <div>
              <label for="displayName" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">
                Apodo para la Quiniela (Cupo #1)
              </label>
              <input
                id="displayName"
                name="displayName"
                type="text"
                required
                class="w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all duration-200"
                placeholder="Ej: Alirio #1"
              />
              <p class="text-[10px] text-slate-500 mt-1">Este nombre saldrá en la tabla de posiciones.</p>
            </div>

            <div>
              <label for="email" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">
                Correo Electrónico
              </label>
              <input
                id="email"
                name="email"
                type="email"
                required
                class="w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all duration-200"
                placeholder="tu@correo.com"
              />
            </div>

            <div>
              <label for="birthDate" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">
                Fecha de Nacimiento
              </label>
              <input
                id="birthDate"
                name="birthDate"
                type="date"
                required
                class="w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all duration-200"
              />
              <p class="text-[10px] text-slate-500 mt-1">Debes ser mayor de 18 años para participar.</p>
            </div>

            <div class="md:col-span-2">
              <label for="password" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">
                Contraseña
              </label>
              <input
                id="password"
                name="password"
                type="password"
                required
                minlength="6"
                class="w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all duration-200"
                placeholder="Mínimo 6 caracteres"
              />
            </div>
          </div>

          <div class="space-y-4 pt-4">
            <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-300 border-b border-slate-800/80 pb-2">
              Detalles de Pago y Comprobante
            </h2>
            
            <!-- Componente de desglose -->
            <PaymentBreakdown />
            
            <!-- Isla Reactiva de carga de archivos -->
            <PaymentUpload client:load initialLabel="Sube tu comprobante de 20 USDT" />
          </div>

          <div class="pt-4">
            <button
              type="submit"
              id="submit-btn"
              class="w-full py-4 px-4 rounded-xl text-sm font-semibold bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-400 hover:to-teal-500 text-slate-950 shadow-lg shadow-emerald-950/20 hover:shadow-emerald-950/40 hover:-translate-y-0.5 transition-all duration-200 flex items-center justify-center gap-2 group font-bold"
            >
              <span>Crear Cuenta y Registrar Cupo</span>
              <UserPlus className="w-4 h-4 text-slate-950 group-hover:scale-110 transition-all" />
            </button>
          </div>
        </form>
      )}

      <div class="text-center text-sm text-slate-400 border-t border-slate-800/80 pt-6">
        ¿Ya tienes una cuenta?
        <a href="/login" class="font-semibold text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-300 hover:opacity-90 transition-opacity">
          Inicia sesión aquí
        </a>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('register-form') as HTMLFormElement;
    const errorDiv = document.getElementById('error-message');
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const USER_PLUS_SVG = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-slate-950 group-hover:scale-110 transition-all"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><line x1="19" x2="19" y1="8" y2="14"></line><line x1="22" x2="16" y1="11" y2="11"></line></svg>`;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!errorDiv || !submitBtn) return;

      errorDiv.classList.add('hidden');

      // Validar edad >= 18 en el cliente
      const birthDateInput = document.getElementById('birthDate') as HTMLInputElement;
      if (birthDateInput) {
        const birthDateVal = new Date(birthDateInput.value);
        if (isNaN(birthDateVal.getTime())) {
          errorDiv.textContent = 'Por favor, ingresa una fecha de nacimiento válida.';
          errorDiv.classList.remove('hidden');
          return;
        }
        const today = new Date();
        let age = today.getFullYear() - birthDateVal.getFullYear();
        const m = today.getMonth() - birthDateVal.getMonth();
        if (m < 0 || (m === 0 && today.getDate() < birthDateVal.getDate())) {
          age--;
        }
        if (age < 18) {
          errorDiv.textContent = 'Debes ser mayor de 18 años para participar en la quiniela.';
          errorDiv.classList.remove('hidden');
          return;
        }
      }

      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span>Procesando registro...</span>';

      const formData = new FormData(form);

      try {
        const response = await fetch('/api/auth/register', {
          method: 'POST',
          body: formData
        });

        const data = await response.json();

        if (response.ok) {
          // El registro fue exitoso y el endpoint setea las cookies de sesión,
          // redirigimos a la página pendiente
          window.location.href = '/pending';
        } else {
          errorDiv.textContent = data.error || 'Error al completar el registro';
          errorDiv.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.innerHTML = `<span>Crear Cuenta y Registrar Cupo</span>${USER_PLUS_SVG}`;
        }
      } catch (err) {
        errorDiv.textContent = 'Error de conexión. Inténtalo de nuevo.';
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.innerHTML = `<span>Crear Cuenta y Registrar Cupo</span>${USER_PLUS_SVG}`;
      }
    });
  </script>
</MainLayout>
